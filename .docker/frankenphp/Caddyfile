{
	{$CADDY_GLOBAL_OPTIONS}

	# FRANKENPHP_CONFIG is set by frankenphp/docker-entrypoint.sh from FRANKENPHP_MODE:
	#   classic → empty (classic php_server, boot per request)
	#   worker  → "worker { file ./public/index.php ... }" (app kept in memory)
	#
	# Important: the worker MUST point at the front controller (public/index.php).
	# Symfony ≥7.4 detects $_SERVER['FRANKENPHP_WORKER']=1 (injected by FrankenPHP)
	# and uses FrankenPhpWorkerRunner → frankenphp_handle_request().
	frankenphp {
		{$FRANKENPHP_CONFIG}
	}

	# Host maps container :80/:443 to HTTP_PORT/HTTPS_PORT (e.g. 9081/9444).
	# Caddy's default HTTP→HTTPS redirect would send browsers to https://localhost/
	# (port 443). Disable it and redirect to DEFAULT_URI instead.
	auto_https disable_redirects
}

{$CADDY_EXTRA_CONFIG}

# HTTP for local + Docker clients (BeaconBundle demo → host.docker.internal:9081).
# Serve Envelope ingest on HTTP; redirect other browser traffic to HTTPS UI.
http://{$SERVER_NAME:localhost}, http://host.docker.internal, http://127.0.0.1 {
	@ingest path /api/*

	handle @ingest {
		root * /app/public
		encode zstd br gzip
		{$CADDY_SERVER_EXTRA_DIRECTIVES}
		php_server
	}

	handle {
		redir {$DEFAULT_URI:https://localhost:9444}{uri} permanent
	}
}

{$SERVER_NAME:localhost} {
	log {
		{$CADDY_SERVER_LOG_OPTIONS}
	}

	# Symfony document root
	root * /app/public
	encode zstd br gzip

	{$CADDY_SERVER_EXTRA_DIRECTIVES}

	# Vite HMR / assets (dev) — same-origin HTTPS so Tailwind CSS loads in the browser.
	handle /build* {
		reverse_proxy vite:5173
	}

	# classic: run PHP per request.
	# worker:  if a worker is registered for ./public/index.php, requests to that
	#          script are handled by the worker (no re-bootstrap).
	php_server
}
