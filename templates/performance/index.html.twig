{% extends 'base.html.twig' %}

{% block title %}{{ 'performance.title'|trans }} — {{ project.name }}{% endblock %}

{% block body %}
{% include 'project/_nav.html.twig' with {project: project, current: 'performance'} %}

<div class="mb-6 flex flex-wrap items-end justify-between gap-4">
    <p class="text-[var(--color-ink)]/65">{{ 'performance.intro'|trans }}</p>
    <a class="btn-ghost no-underline" href="{{ path('performance_index', {id: project.id, nplus1: nPlusOneOnly ? 0 : 1}) }}">
        {% if nPlusOneOnly %}{{ 'performance.show_all'|trans }}{% else %}{{ 'performance.nplus1_only'|trans }}{% endif %}
    </a>
</div>

{% if transactions is empty %}
    <div class="panel text-[var(--color-ink)]/70">{{ 'performance.empty'|trans }}</div>
{% else %}
    <div class="panel overflow-x-auto p-0">
        <table class="w-full text-left text-sm">
            <thead class="border-b border-[var(--color-sand)] bg-[var(--color-paper)] text-xs uppercase tracking-wide text-[var(--color-ink)]/55">
                <tr>
                    <th class="px-4 py-3">{{ 'performance.col.transaction'|trans }}</th>
                    <th class="px-4 py-3">{{ 'performance.col.duration'|trans }}</th>
                    <th class="px-4 py-3">{{ 'performance.col.spans'|trans }}</th>
                    <th class="px-4 py-3">{{ 'performance.col.nplus1'|trans }}</th>
                    <th class="px-4 py-3">{{ 'performance.col.received'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for tx in transactions %}
                    <tr class="border-b border-[var(--color-sand)] last:border-0">
                        <td class="px-4 py-3">
                            <a class="font-medium no-underline" href="{{ path('performance_show', {projectId: project.id, id: tx.id}) }}">{{ tx.transactionName }}</a>
                        </td>
                        <td class="px-4 py-3">{{ tx.durationMs|number_format(1) }} ms</td>
                        <td class="px-4 py-3">{{ tx.spanCount }}</td>
                        <td class="px-4 py-3">
                            {% if tx.nPlusOneCount > 0 %}
                                <span class="badge badge-warn">{{ tx.nPlusOneCount }}</span>
                            {% else %}
                                <span class="text-[var(--color-ink)]/45">0</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3 whitespace-nowrap">{{ tx.receivedAt|date('Y-m-d H:i') }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
