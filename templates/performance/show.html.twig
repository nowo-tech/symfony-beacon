{% extends 'base.html.twig' %}

{% block title %}{{ transaction.transactionName }}{% endblock %}

{% block body %}
<a href="{{ path('performance_index', {id: project.id}) }}" class="text-sm no-underline">{{ 'performance.back'|trans }}</a>
<h1 class="mt-2 font-[family-name:var(--font-display)] text-3xl font-bold">{{ transaction.transactionName }}</h1>
<p class="mt-1 text-sm text-[var(--color-ink)]/65">
    {{ transaction.durationMs|number_format(1) }} ms · {{ 'performance.spans_count'|trans({'%count%': transaction.spanCount}) }} ·
    {% if transaction.nPlusOneCount > 0 %}
        <span class="text-[var(--color-warn)]">{{ 'performance.nplus1_groups'|trans({'%count%': transaction.nPlusOneCount}) }}</span>
    {% else %}
        {{ 'performance.no_nplus1'|trans }}
    {% endif %}
</p>

<section class="panel mt-6 overflow-x-auto p-0">
    <table class="w-full text-left text-sm">
        <thead class="border-b border-[var(--color-sand)] bg-[var(--color-paper)] text-xs uppercase tracking-wide text-[var(--color-ink)]/55">
            <tr>
                <th class="px-4 py-3">{{ 'performance.col.op'|trans }}</th>
                <th class="px-4 py-3">{{ 'performance.col.description'|trans }}</th>
                <th class="px-4 py-3">{{ 'performance.col.duration'|trans }}</th>
                <th class="px-4 py-3">{{ 'performance.col.nplus1'|trans }}</th>
            </tr>
        </thead>
        <tbody>
            {% for span in transaction.spans %}
                <tr class="border-b border-[var(--color-sand)] last:border-0 {% if span.nPlusOneCandidate %}bg-amber-50{% endif %}">
                    <td class="px-4 py-3 font-mono text-xs">{{ span.op }}</td>
                    <td class="px-4 py-3 font-mono text-xs">{{ span.description }}</td>
                    <td class="px-4 py-3">{{ span.durationMs|number_format(1) }} ms</td>
                    <td class="px-4 py-3">{% if span.nPlusOneCandidate %}{{ 'common.yes'|trans }}{% else %}—{% endif %}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</section>
{% endblock %}
