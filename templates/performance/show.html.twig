{% extends 'base.html.twig' %}

{% block title %}{{ transaction.transactionName }} — {{ project.name }}{% endblock %}

{% block body %}
{% include 'project/_nav.html.twig' with {project: project, current: 'performance'} %}

<a href="{{ path('performance_index', {id: project.id}) }}" class="text-sm no-underline">{{ 'performance.back'|trans }}</a>

<header class="perf-tx-hero mt-3">
    <h1 class="perf-tx-hero__title font-[family-name:var(--font-display)]">{{ transaction.transactionName }}</h1>
    <ul class="perf-tx-hero__meta">
        <li>{{ transaction.durationMs|number_format(1) }} ms</li>
        <li>{{ 'performance.spans_count'|trans({'%count%': transaction.spanCount}) }}</li>
        <li>
            {% if transaction.nPlusOneCount > 0 %}
                <span class="badge badge-warn">{{ 'performance.nplus1_groups'|trans({'%count%': transaction.nPlusOneCount}) }}</span>
            {% else %}
                <span class="text-[var(--color-ink)]/55">{{ 'performance.no_nplus1'|trans }}</span>
            {% endif %}
        </li>
        <li class="text-[var(--color-ink)]/55">{{ transaction.receivedAt|date('Y-m-d H:i:s') }}</li>
    </ul>
</header>

<section class="panel perf-span-panel mt-6 overflow-x-auto p-0">
    <table class="perf-span-table w-full text-left text-sm">
        <thead>
            <tr>
                <th>{{ 'performance.col.op'|trans }}</th>
                <th>{{ 'performance.col.description'|trans }}</th>
                <th class="perf-span-table__num">{{ 'performance.col.duration'|trans }}</th>
                <th>{{ 'performance.col.nplus1'|trans }}</th>
            </tr>
        </thead>
        <tbody>
            {% for span in transaction.spans %}
                <tr class="{% if span.nPlusOneCandidate %}is-nplus1{% endif %}">
                    <td class="perf-span-table__op">{{ span.op }}</td>
                    <td class="perf-span-table__desc">{{ span.description }}</td>
                    <td class="perf-span-table__num">{{ span.durationMs|number_format(1) }} ms</td>
                    <td>
                        {% if span.nPlusOneCandidate %}
                            <span class="badge badge-warn">{{ 'performance.nplus1_flag'|trans }}</span>
                        {% else %}
                            <span class="perf-span-table__empty">—</span>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</section>
{% endblock %}
