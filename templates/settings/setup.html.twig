{% extends 'layouts/guest_shell.html.twig' %}

{% block title %}{{ 'setup.title'|trans }} — {{ site_appearance.brandName }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-2xl">
    <div class="mb-6">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-moss)]">{{ 'setup.eyebrow'|trans }}</p>
        <h1 class="mt-2 font-[family-name:var(--font-display)] text-3xl font-bold">{{ 'setup.title'|trans }}</h1>
        <p class="mt-2 text-sm text-[var(--color-ink)]/65">
            {% if needsPlatformSeed %}
                {{ 'setup.intro_required'|trans }}
            {% elseif bootstrapMode %}
                {{ 'setup.intro_bootstrap'|trans }}
            {% else %}
                {{ 'setup.intro'|trans }}
            {% endif %}
        </p>
    </div>

    {% if setupCompleted and not needsPlatformSeed %}
        <div class="panel mb-6 border-[var(--color-moss)]/40 bg-[var(--beacon-flash-ok-bg)] text-sm text-[var(--beacon-flash-ok-text)]">
            {{ 'setup.already_done'|trans }}
            <a class="ml-2 font-semibold underline" href="{{ path('dashboard_home') }}">{{ 'setup.back_dashboard'|trans }}</a>
        </div>
    {% endif %}

    <ol class="grid gap-4">
        <li class="panel">
            <h2 class="text-lg font-semibold">1. {{ 'setup.step_platform.title'|trans }}</h2>
            <p class="mt-1 text-sm text-[var(--color-ink)]/65">{{ 'setup.step_platform.body'|trans }}</p>
            <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-[var(--color-ink)]/70">
                <li>{{ 'setup.step_platform.item_menus'|trans }}</li>
                <li>{{ 'setup.step_platform.item_breadcrumbs'|trans }}</li>
                <li>{{ 'setup.step_platform.item_cookies'|trans }}</li>
            </ul>
            {% if needsPlatformSeed %}
                <form method="post" action="{{ path(setupRunRoute, setupRouteParams) }}" class="mt-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('setup_wizard') }}">
                    <input type="hidden" name="action" value="platform">
                    <button type="submit" class="btn-primary">{{ 'setup.step_platform.cta'|trans }}</button>
                </form>
            {% else %}
                <p class="mt-3 text-sm text-[var(--color-moss)]">{{ 'setup.step_platform.done'|trans }}</p>
                <form method="post" action="{{ path(setupRunRoute, setupRouteParams) }}" class="mt-3">
                    <input type="hidden" name="_token" value="{{ csrf_token('setup_wizard') }}">
                    <input type="hidden" name="action" value="platform">
                    <button type="submit" class="btn-ghost">{{ 'setup.step_platform.cta_again'|trans }}</button>
                </form>
            {% endif %}
        </li>

        <li class="panel {% if needsPlatformSeed %}opacity-60{% endif %}">
            <h2 class="text-lg font-semibold">2. {{ 'setup.step_options.title'|trans }}</h2>
            <p class="mt-1 text-sm text-[var(--color-ink)]/65">{{ 'setup.step_options.body'|trans }}</p>
            {% if needsPlatformSeed %}
                <p class="mt-3 text-sm text-[var(--color-ink)]/55">{{ 'setup.step_options.locked'|trans }}</p>
            {% else %}
                <div class="mt-4 grid gap-4">
                    <div>
                        <h3 class="text-sm font-semibold">{{ 'setup.step_options.register_title'|trans }}</h3>
                        <p class="mt-1 text-sm text-[var(--color-ink)]/65">{{ 'setup.step_options.register_body'|trans }}</p>
                        {% if hasUsers %}
                            <p class="mt-2 text-sm text-[var(--color-moss)]">{{ 'setup.step_options.register_done'|trans }}</p>
                        {% else %}
                            <a class="btn-primary mt-3 inline-flex no-underline" href="{{ path('nowo_auth_kit_register', auth_kit_route_params()) }}">{{ 'setup.step_options.register_cta'|trans }}</a>
                        {% endif %}
                    </div>

                    <div>
                        <h3 class="text-sm font-semibold">{{ 'setup.step_options.sample_title'|trans }}</h3>
                        <p class="mt-1 text-sm text-[var(--color-ink)]/65">{{ 'setup.step_options.sample_body'|trans }}</p>
                        {% if hasDemoProject %}
                            <p class="mt-2 text-sm text-[var(--color-moss)]">{{ 'setup.step_demo.exists'|trans }}</p>
                        {% endif %}
                        <form method="post" action="{{ path(setupRunRoute, setupRouteParams) }}" class="mt-3">
                            <input type="hidden" name="_token" value="{{ csrf_token('setup_wizard') }}">
                            <input type="hidden" name="action" value="sample_load">
                            <button type="submit" class="btn-ghost">{{ 'setup.step_options.sample_cta'|trans }}</button>
                        </form>
                        <p class="mt-2 text-xs text-[var(--color-ink)]/55">{{ 'setup.step_options.sample_note'|trans }}</p>
                    </div>

                    {% if not bootstrapMode %}
                        <div>
                            <h3 class="text-sm font-semibold">{{ 'setup.step_demo.title'|trans }}</h3>
                            <p class="mt-1 text-sm text-[var(--color-ink)]/65">{{ 'setup.step_demo.body'|trans }}</p>
                            <form method="post" action="{{ path(setupRunRoute, setupRouteParams) }}" class="mt-3">
                                <input type="hidden" name="_token" value="{{ csrf_token('setup_wizard') }}">
                                <input type="hidden" name="action" value="demo">
                                <button type="submit" class="btn-ghost">{{ 'setup.step_demo.cta'|trans }}</button>
                            </form>
                        </div>

                        <div>
                            <h3 class="text-sm font-semibold">{{ 'setup.step_sample.title'|trans }}</h3>
                            <p class="mt-1 text-sm text-[var(--color-ink)]/65">{{ 'setup.step_sample.body'|trans }}</p>
                            <div class="mt-3 flex flex-wrap gap-2">
                                <form method="post" action="{{ path(setupRunRoute, setupRouteParams) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('setup_wizard') }}">
                                    <input type="hidden" name="action" value="sample_dev">
                                    <button type="submit" class="btn-ghost" {% if not hasDemoProject %}disabled{% endif %}>{{ 'setup.step_sample.dev'|trans }}</button>
                                </form>
                            </div>
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        </li>

        <li class="panel {% if needsPlatformSeed %}opacity-60{% endif %}">
            <h2 class="text-lg font-semibold">3. {{ 'setup.step_done.title'|trans }}</h2>
            <p class="mt-1 text-sm text-[var(--color-ink)]/65">{{ 'setup.step_done.body'|trans }}</p>
            {% if needsPlatformSeed %}
                <p class="mt-3 text-sm text-[var(--color-ink)]/55">{{ 'setup.step_options.locked'|trans }}</p>
            {% else %}
                <form method="post" action="{{ path(setupRunRoute, setupRouteParams) }}" class="mt-4 flex flex-wrap gap-2">
                    <input type="hidden" name="_token" value="{{ csrf_token('setup_wizard') }}">
                    <input type="hidden" name="action" value="complete">
                    <button type="submit" class="btn-primary">{{ 'setup.step_done.cta'|trans }}</button>
                    {% if hasUsers %}
                        <a class="btn-ghost no-underline" href="{{ path('dashboard_home') }}">{{ 'setup.back_dashboard'|trans }}</a>
                    {% else %}
                        <a class="btn-ghost no-underline" href="{{ path('nowo_auth_kit_login', auth_kit_route_params()) }}">{{ 'setup.bootstrap_login_link'|trans }}</a>
                    {% endif %}
                </form>
            {% endif %}
        </li>
    </ol>

    <p class="mt-6 text-xs text-[var(--color-ink)]/50">{{ 'setup.cli_hint'|trans }}</p>
</div>
{% endblock %}
