{% extends 'base.html.twig' %}

{% block title %}{{ group.name }} — {{ 'groups.title'|trans }}{% endblock %}

{% block body %}
<div class="mb-6 flex flex-wrap items-start justify-between gap-3">
    <div>
        <a href="{{ path('admin_groups') }}" class="text-sm no-underline">{{ 'groups.back'|trans }}</a>
        <h1 class="mt-2 font-[family-name:var(--font-display)] text-3xl font-bold">{{ group.name }}</h1>
        {% if group.description %}
            <p class="mt-1 text-sm text-[var(--color-ink)]/65">{{ group.description }}</p>
        {% endif %}
    </div>
    <div class="flex flex-wrap gap-2">
        <a class="btn-ghost no-underline" href="{{ path('admin_groups_edit', {id: group.uuid}) }}">{{ 'groups.edit'|trans }}</a>
        <form method="post" action="{{ path('admin_groups_delete', {id: group.uuid}) }}" onsubmit="return confirm('{{ 'groups.delete_confirm'|trans|e('js') }}')">
            <input type="hidden" name="_token" value="{{ csrf_token('admin_group_delete_' ~ group.id) }}">
            <button class="btn-danger" type="submit">{{ 'groups.delete'|trans }}</button>
        </form>
    </div>
</div>

<section class="panel mb-6">
    <h2 class="mb-3 text-lg font-semibold">{{ 'groups.members_title'|trans }}</h2>
    <ul class="space-y-2 text-sm">
        {% for membership in group.memberships %}
            <li class="flex flex-wrap items-center justify-between gap-2 border-b border-[var(--color-sand)] py-2 last:border-0">
                <div>
                    <div class="font-medium">{{ membership.user.displayName }}</div>
                    <div class="text-xs text-[var(--color-ink)]/55">{{ membership.user.email }}</div>
                </div>
                <form method="post" action="{{ path('admin_groups_members_remove', {groupId: group.uuid, userId: membership.user.uuid}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_group_member_remove_' ~ membership.id) }}">
                    <button class="btn-ghost" type="submit">{{ 'groups.remove_member'|trans }}</button>
                </form>
            </li>
        {% else %}
            <li class="text-[var(--color-ink)]/55">{{ 'groups.members_empty'|trans }}</li>
        {% endfor %}
    </ul>

    <form method="post" action="{{ path('admin_groups_members_add', {id: group.uuid}) }}" class="mt-4 flex flex-wrap gap-2">
        <input type="hidden" name="_token" value="{{ csrf_token('admin_group_member_add_' ~ group.id) }}">
        <input class="input min-w-56 flex-1" type="email" name="email" required placeholder="{{ 'groups.member_email_placeholder'|trans }}" autocomplete="off">
        <button class="btn-primary" type="submit">{{ 'groups.add_member'|trans }}</button>
    </form>
    <p class="mt-2 text-xs text-[var(--color-ink)]/55">{{ 'groups.add_member_help'|trans }}</p>
</section>

<section class="panel">
    <h2 class="mb-1 text-lg font-semibold">{{ 'groups.projects_title'|trans }}</h2>
    <p class="mb-3 text-sm text-[var(--color-ink)]/60">{{ 'groups.projects_intro'|trans }}</p>
    <ul class="space-y-2 text-sm">
        {% for access in projectAccesses %}
            <li class="flex flex-wrap items-center justify-between gap-2 border-b border-[var(--color-sand)] py-2 last:border-0">
                <div>
                    <a class="font-medium no-underline" href="{{ path('project_settings', {id: access.project.uuid}) }}">{{ access.project.name }}</a>
                    <div class="text-xs text-[var(--color-ink)]/55">{{ ('project.members.role.' ~ access.role.value)|trans }}</div>
                </div>
                <form method="post" action="{{ path('admin_groups_projects_remove', {groupId: group.uuid, accessId: access.uuid}) }}" onsubmit="return confirm('{{ 'groups.unlink_project_confirm'|trans({'%project%': access.project.name})|e('js') }}')">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_group_project_remove_' ~ access.id) }}">
                    <button class="btn-ghost" type="submit">{{ 'groups.unlink_project'|trans }}</button>
                </form>
            </li>
        {% else %}
            <li class="text-[var(--color-ink)]/55">{{ 'groups.projects_empty'|trans }}</li>
        {% endfor %}
    </ul>
</section>
{% endblock %}
