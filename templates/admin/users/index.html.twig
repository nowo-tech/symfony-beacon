{% extends 'base.html.twig' %}

{% block title %}{{ 'users.title'|trans }} — {{ site_appearance.brandName }}{% endblock %}

{% block body %}
<div class="mb-6">
    <h1 class="font-[family-name:var(--font-display)] text-3xl font-bold">{{ 'users.title'|trans }}</h1>
    <p class="mt-1 text-sm text-[var(--color-ink)]/65">{{ 'users.intro'|trans }}</p>
</div>

<section class="panel overflow-x-auto">
    <table class="w-full text-left text-sm">
        <thead>
            <tr class="border-b border-[var(--color-sand)] text-[var(--color-ink)]/55">
                <th class="px-2 py-2 font-medium">{{ 'users.col.user'|trans }}</th>
                <th class="px-2 py-2 font-medium">{{ 'users.col.email'|trans }}</th>
                <th class="px-2 py-2 font-medium">{{ 'users.col.roles'|trans }}</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
                <tr class="row-hover border-b border-[var(--color-sand)]/70 last:border-0">
                    <td class="px-2 py-3">
                        <div class="flex items-center gap-2">
                            <span class="user-avatar user-avatar--sm" aria-hidden="true">{{ user.initials }}</span>
                            <span class="font-medium">{{ user.displayName }}</span>
                        </div>
                    </td>
                    <td class="px-2 py-3 text-[var(--color-ink)]/75">{{ user.email }}</td>
                    <td class="px-2 py-3">
                        <div class="flex flex-wrap gap-1">
                            {% for role in user.roles %}
                                <span class="badge bg-[var(--color-sand)]">{{ role }}</span>
                            {% endfor %}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td class="px-2 py-4 text-[var(--color-ink)]/55" colspan="3">{{ 'users.empty'|trans }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</section>
{% endblock %}
