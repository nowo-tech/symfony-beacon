{% extends 'base.html.twig' %}

{% block title %}{{ 'users.activity.title'|trans }} — {{ user.displayName }}{% endblock %}

{% block body %}
<div class="mb-6">
    <a href="{{ path('admin_users') }}" class="text-sm no-underline">{{ 'users.back'|trans }}</a>
    <h1 class="mt-2 font-[family-name:var(--font-display)] text-3xl font-bold">{{ 'users.activity.title'|trans }}</h1>
    <p class="mt-1 text-sm text-[var(--color-ink)]/65">
        {{ 'users.activity.intro'|trans({'%name%': user.displayName, '%email%': user.email}) }}
    </p>
</div>

<section class="panel mb-6">
    <h2 class="mb-1 text-lg font-semibold">{{ 'users.projects_title'|trans }}</h2>
    <p class="mb-3 text-sm text-[var(--color-ink)]/60">{{ 'users.projects_intro'|trans }}</p>
    <ul class="space-y-2 text-sm">
        {% for membership in memberships %}
            <li class="flex flex-wrap items-center justify-between gap-2 border-b border-[var(--color-sand)] py-2 last:border-0">
                <div>
                    <a class="font-medium no-underline" href="{{ path('project_settings', {id: membership.project.uuid}) }}">{{ membership.project.name }}</a>
                    <div class="text-xs text-[var(--color-ink)]/55">{{ ('project.members.role.' ~ membership.role.value)|trans }}</div>
                </div>
                <form method="post" action="{{ path('admin_users_projects_remove', {userId: user.uuid, projectId: membership.project.uuid}) }}" onsubmit="return confirm('{{ 'users.remove_from_project_confirm'|trans({'%project%': membership.project.name})|e('js') }}')">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_user_project_remove_' ~ membership.id) }}">
                    <button class="btn-ghost" type="submit">{{ 'users.remove_from_project'|trans }}</button>
                </form>
            </li>
        {% else %}
            <li class="text-[var(--color-ink)]/55">{{ 'users.projects_empty'|trans }}</li>
        {% endfor %}
    </ul>
</section>

<section class="panel">
    <h2 class="mb-3 text-lg font-semibold">{{ 'users.activity.timeline_title'|trans }}</h2>
    {% if actions is empty %}
        <p class="text-sm text-[var(--color-ink)]/55">{{ 'users.activity.empty'|trans }}</p>
    {% else %}
        <ul class="space-y-3 text-sm">
            {% for entry in actions %}
                <li class="border-b border-[var(--color-sand)] pb-3 last:border-0 last:pb-0">
                    <div class="flex flex-wrap items-baseline justify-between gap-2">
                        <span class="font-medium">{{ ('users.activity.action.' ~ entry.action.value)|trans }}</span>
                        <time class="text-xs text-[var(--color-ink)]/50" datetime="{{ entry.createdAt|date('c') }}">{{ entry.createdAt|date('Y-m-d H:i') }}</time>
                    </div>
                    <div class="mt-1 text-xs text-[var(--color-ink)]/65">
                        {% if entry.actor %}
                            {{ 'users.activity.by'|trans({'%name%': entry.actor.displayName}) }}
                        {% else %}
                            {{ 'users.activity.by_system'|trans }}
                        {% endif %}
                        {% if entry.subjectUser and (not entry.actor or entry.subjectUser.id != entry.actor.id) %}
                            · {{ 'users.activity.subject'|trans({'%name%': entry.subjectUser.displayName}) }}
                        {% endif %}
                        {% if entry.ipAddress %}
                            · {{ entry.ipAddress }}
                        {% endif %}
                    </div>
                    {% if entry.context is not empty %}
                        <dl class="mt-2 grid gap-1 text-xs text-[var(--color-ink)]/60 sm:grid-cols-2">
                            {% for key, value in entry.context %}
                                <div>
                                    <dt class="inline font-medium">{{ ('users.activity.context.' ~ key)|trans }}:</dt>
                                    <dd class="inline">{{ value }}</dd>
                                </div>
                            {% endfor %}
                        </dl>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</section>
{% endblock %}
