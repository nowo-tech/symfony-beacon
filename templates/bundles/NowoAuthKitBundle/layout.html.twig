{# Override AuthKit layout — Tailwind shell aligned with app base. #}
<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    {% if app.user and app.user.preferredTheme %}
        <script>window.__BEACON_USER_THEME__ = {{ app.user.preferredTheme|json_encode|raw }};</script>
    {% endif %}
    {% include '_theme_boot.html.twig' %}
    <title>{% block title %}{{ site_appearance.brandName }}{% endblock %}</title>
    <style>{{ site_appearance.cssOverrides|raw }}</style>
    {% if not ux_is_native() %}
        {{ nowo_pwa_head() }}
    {% endif %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=Source+Serif+4:opsz,wght@8..60,600;8..60,700&display=swap" rel="stylesheet">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🟩</text></svg>">
    {{ vite_entry_link_tags('app') }}
    {{ vite_entry_script_tags('app') }}
    <link rel="stylesheet" href="{{ asset('css/toggle_password.css', 'nowo_password_toggle') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body class="page-shell{% if ux_is_native() %} page-shell--native{% endif %}"{% if ux_is_native() %} data-controller="beacon-theme-bridge"{% endif %}>
    <div class="top-controls">
        {% include '_theme_toggle.html.twig' %}
        {% if not ux_is_native() %}
            {% include '_locale_switcher.html.twig' %}
        {% endif %}
    </div>
    <main class="auth-shell-main relative z-10 mx-auto flex w-full max-w-6xl flex-1 justify-center px-4 py-12">
        <div class="w-full max-w-md">
            {% block body %}{% endblock %}
        </div>
    </main>
    <script src="{{ asset('password-strength.js', 'nowo_password_strength') }}" defer></script>
    {% block javascripts %}{% endblock %}
    {% if not ux_is_native() %}
        {{ nowo_pwa_install_prompt() }}
        {% include '_legal_footer.html.twig' %}
        {# Always embed CMP on login/register; floating bubble only here. #}
        {{ render(path('nowo_cookie_consent.show')) }}
        {% include '@NowoCookieConsentBundle/cookie_consent_preferences_bubble.html.twig' %}
    {% endif %}
</body>
</html>
