{% extends layout_template %}

{% form_theme registration_form with [
    '@PasswordStrengthBundle/Form/password_strength_theme_tailwind2.html.twig',
    'form/auth_kit_theme.html.twig'
] %}

{% block title %}{{ 'register.title'|trans({}, 'NowoAuthKitBundle') }} — {{ site_appearance.brandName }}{% endblock %}

{% block body %}
<div class="fade-up mb-8 text-center">
    <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-moss)]">{{ 'auth.bootstrap_eyebrow'|trans }}</p>
    {% include '_brand_mark.html.twig' with {tag: 'h1', size: 'hero'} %}
    <p class="mx-auto mt-2.5 max-w-sm text-sm leading-relaxed text-[var(--color-ink)]/65">
        {{ 'auth.bootstrap_hint'|trans }}
    </p>
</div>

<div class="fade-up-delay panel shadow-md">
    <h2 class="mb-4 text-lg font-semibold text-[var(--color-ink)]">{{ 'register.heading'|trans({}, 'NowoAuthKitBundle') }}</h2>

    {{ form_start(registration_form, {attr: {class: 'space-y-4'}}) }}
        {% for field in registration_form %}
            {{ form_row(field) }}
        {% endfor %}
        <button type="submit" class="btn-primary w-full">{{ 'register.submit'|trans({}, 'NowoAuthKitBundle') }}</button>
    {{ form_end(registration_form) }}

    <p class="mt-5 text-center text-sm text-[var(--color-ink)]/60">
        <a href="{{ path(login_route, auth_kit_route_params()) }}" class="no-underline font-medium">{{ 'register.login_link'|trans({}, 'NowoAuthKitBundle') }}</a>
    </p>
</div>
{% endblock %}
