{% extends layout_template %}

{% form_theme login_form 'form/auth_kit_theme.html.twig' %}

{% block title %}{{ 'login.title'|trans({}, 'NowoAuthKitBundle') }} — symfony-beacon{% endblock %}

{% block body %}
<div class="fade-up mb-10 text-center">
    <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-moss)]">Error tracking</p>
    <h1 class="brand-mark text-4xl sm:text-5xl">symfony-beacon</h1>
    <p class="mx-auto mt-3 max-w-sm text-base leading-relaxed text-[var(--color-ink)]/65">
        Self-hosted error tracking for PHP &amp; Symfony.
    </p>
</div>

<div class="fade-up-delay panel shadow-md">
    <h2 class="mb-4 text-lg font-semibold text-[var(--color-ink)]">{{ 'login.heading'|trans({}, 'NowoAuthKitBundle') }}</h2>

    {% if error %}
        <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-[var(--color-alert)]" role="alert">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    {{ form_start(login_form, {attr: {class: 'space-y-4'}}) }}
        {{ form_row(login_form._username) }}
        {{ form_row(login_form._password) }}
        {% if login_form._remember_me is defined %}
            {{ form_row(login_form._remember_me) }}
        {% endif %}
        <button type="submit" class="btn-primary w-full">{{ 'login.submit'|trans({}, 'NowoAuthKitBundle') }}</button>
    {{ form_end(login_form) }}

    {% if password_reset_enabled|default(false) or registration_allowed|default(false) %}
        <p class="mt-5 text-center text-sm text-[var(--color-ink)]/60">
            {% if password_reset_enabled|default(false) %}
                <a href="{{ path(reset_password_route, auth_kit_route_params()) }}" class="no-underline">{{ 'login.forgot_password_link'|trans({}, 'NowoAuthKitBundle') }}</a>
                {% if registration_allowed|default(false) %} · {% endif %}
            {% endif %}
            {% if registration_allowed|default(false) %}
                <a href="{{ path(register_route, auth_kit_route_params()) }}" class="no-underline font-medium">{{ 'login.register_link'|trans({}, 'NowoAuthKitBundle') }}</a>
            {% endif %}
        </p>
    {% endif %}
</div>
{% endblock %}
