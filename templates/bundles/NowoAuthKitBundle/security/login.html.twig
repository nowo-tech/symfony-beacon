{% extends layout_template %}

{% form_theme login_form with [
    'form/password_strength_beacon_theme.html.twig',
    'form/auth_kit_theme.html.twig'
] %}

{% set outbound_mail_ready = beacon_magic_login_enabled() %}
{% set show_magic_login = outbound_mail_ready and magic_login_enabled|default(false) %}
{% set show_password_reset = outbound_mail_ready and password_reset_enabled|default(false) %}

{% block title %}{{ 'login.title'|trans({}, 'NowoAuthKitBundle') }} — {{ site_appearance.brandName }}{% endblock %}

{% block body %}
<div class="fade-up mb-8 text-center">
    <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-moss)]">{{ site_appearance.brandEyebrow }}</p>
    {% include '_brand_mark.html.twig' with {tag: 'h1', size: 'hero'} %}
    <p class="mx-auto mt-2.5 max-w-sm text-sm leading-relaxed text-[var(--color-ink)]/65">
        {{ 'auth.tagline'|trans }}
    </p>
</div>

<div class="fade-up-delay panel shadow-md">
    <h2 class="mb-4 text-lg font-semibold text-[var(--color-ink)]">{{ 'login.heading'|trans({}, 'NowoAuthKitBundle') }}</h2>

    {% if error %}
        <div class="flash flash-error mb-4" role="alert">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    {{ form_start(login_form, {attr: {class: 'space-y-4'}}) }}
        {{ form_row(login_form._username) }}
        {{ form_row(login_form._password) }}
        {% if login_form._remember_me is defined %}
            {{ form_row(login_form._remember_me) }}
        {% endif %}
        <button type="submit" class="btn-primary w-full">{{ 'login.submit'|trans({}, 'NowoAuthKitBundle') }}</button>
    {{ form_end(login_form) }}

    {% if show_magic_login %}
        <p class="mt-4 text-center text-sm text-[var(--color-ink)]/60">
            <a href="{{ path(magic_login_route, auth_kit_route_params()) }}" class="no-underline font-medium">{{ 'auth.magic.title'|trans }}</a>
        </p>
    {% endif %}

    {% if show_password_reset or registration_allowed|default(false) or beacon_setup_bootstrap_open() %}
        <p class="mt-5 text-center text-sm text-[var(--color-ink)]/60">
            {% if show_password_reset %}
                <a href="{{ path(reset_password_route, auth_kit_route_params()) }}" class="no-underline">{{ 'login.forgot_password_link'|trans({}, 'NowoAuthKitBundle') }}</a>
                {% if registration_allowed|default(false) or beacon_setup_bootstrap_open() %} · {% endif %}
            {% endif %}
            {% if registration_allowed|default(false) %}
                <a href="{{ path(register_route, auth_kit_route_params()) }}" class="no-underline font-medium">{{ 'login.register_link'|trans({}, 'NowoAuthKitBundle') }}</a>
                {% if beacon_setup_bootstrap_open() %} · {% endif %}
            {% endif %}
            {% if beacon_setup_bootstrap_open() %}
                <a href="{{ beacon_setup_path(app.request.locale|default(default_locale)) }}" class="no-underline font-medium">{{ 'setup.login_setup_link'|trans }}</a>
            {% endif %}
        </p>
    {% endif %}
</div>
{% endblock %}
