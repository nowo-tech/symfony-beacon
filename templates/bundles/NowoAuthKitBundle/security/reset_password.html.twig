{% extends layout_template %}

{% form_theme reset_password_form with [
    'form/password_strength_beacon_theme.html.twig',
    'form/auth_kit_theme.html.twig'
] %}

{% block title %}{{ 'reset.password.title'|trans({}, 'NowoAuthKitBundle') }} — {{ site_appearance.brandName }}{% endblock %}

{% block body %}
<div class="fade-up mb-8 text-center">
    <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-moss)]">{{ site_appearance.brandEyebrow }}</p>
    {% include '_brand_mark.html.twig' with {tag: 'h1', size: 'hero'} %}
</div>

<div class="fade-up-delay panel shadow-md">
    <h2 class="mb-4 text-lg font-semibold text-[var(--color-ink)]">{{ 'reset.password.heading'|trans({}, 'NowoAuthKitBundle') }}</h2>

    {{ form_start(reset_password_form, {attr: {class: 'space-y-4'}}) }}
        {{ form_row(reset_password_form.password) }}
        <button type="submit" class="btn-primary w-full">{{ 'reset.password.submit'|trans({}, 'NowoAuthKitBundle') }}</button>
    {{ form_end(reset_password_form) }}

    <p class="mt-5 text-center text-sm text-[var(--color-ink)]/60">
        <a href="{{ path(login_route, auth_kit_route_params()) }}" class="no-underline">{{ 'reset.password.back_to_login'|trans({}, 'NowoAuthKitBundle') }}</a>
    </p>
</div>
{% endblock %}
