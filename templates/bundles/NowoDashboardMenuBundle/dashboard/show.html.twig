{% extends nowo_dashboard_layout_template|default('@NowoDashboardMenuBundle/dashboard/layout.html.twig') %}

{% block dashboard_title %}{{ 'dashboard.menu'|trans({}, 'NowoDashboardMenuBundle') }}: {{ menu.code }}{% endblock %}

{% block nowo_dashboard_menu_content %}
    {% for msg in app.flashes('success') %}
        <div class="alert alert-success">{{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
        <div class="alert alert-danger">{{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('info') %}
        <div class="alert alert-info">{{ msg }}</div>
    {% endfor %}

    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div class="d-flex flex-wrap align-items-center gap-2">
            <h1 class="h3 mb-0">{% if menu.icon %}<span class="text-muted me-1" title="{{ menu.icon }}">🔣</span>{% endif %}{{ menu.code }}{% if menu.name %} <span class="text-muted fw-normal">({{ menu.name }})</span>{% endif %}</h1>
            {% if items|length > 0 %}
                <a href="{{ path(dashboard_routes.show_items_reorder|default('nowo_dashboard_menu_dashboard_show_items_reorder'), { id: menu.id }) }}" class="btn btn-outline-secondary btn-sm">{{ 'dashboard.open_sortable_reorder'|trans({}, 'NowoDashboardMenuBundle') }}</a>
            {% endif %}
        </div>
        <div class="d-flex flex-wrap align-items-center justify-content-end gap-2">
            <a href="{{ path(dashboard_routes.export_menu|default('nowo_dashboard_menu_dashboard_export_menu'), { id: menu.id }) }}" class="btn btn-outline-secondary" target="_blank" rel="noopener noreferrer">{{ 'dashboard.export'|trans({}, 'NowoDashboardMenuBundle') }}</a>
            <button type="button" class="btn btn-outline-secondary btn-copy-menu" data-id="{{ menu.id }}" data-copy-url="{{ path(dashboard_routes.menu_copy|default('nowo_dashboard_menu_dashboard_menu_copy'), { id: menu.id }) }}" data-bs-toggle="modal" data-bs-target="#modal-menu-copy">{{ 'dashboard.copy'|trans({}, 'NowoDashboardMenuBundle') }}</button>
            <button type="button" class="btn btn-outline-secondary btn-edit-menu" data-id="{{ menu.id }}" data-section="basic" data-bs-toggle="modal" data-bs-target="#modal-menu-form" title="{{ 'dashboard.edit_identity'|trans({}, 'NowoDashboardMenuBundle') }}">{{ 'dashboard.edit_menu'|trans({}, 'NowoDashboardMenuBundle') }}</button>
            {% if not menu.base %}
                <button type="button" class="btn btn-outline-secondary btn-edit-menu btn-edit-menu-config" data-id="{{ menu.id }}" data-section="config" data-bs-toggle="modal" data-bs-target="#modal-menu-form" title="{{ 'dashboard.edit_config'|trans({}, 'NowoDashboardMenuBundle') }}" aria-label="{{ 'dashboard.edit_config'|trans({}, 'NowoDashboardMenuBundle') }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/></svg>
                </button>
            {% endif %}
            {% if items|length > 0 %}
                <form method="post" action="{{ path(dashboard_routes.items_reindex_positions|default('nowo_dashboard_menu_dashboard_items_reindex_positions'), { id: menu.id }) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('reindex_positions_' ~ menu.id) }}">
                    <button type="submit" class="btn btn-outline-secondary" title="{{ 'dashboard.reindex_positions_title'|trans({'%step%': position_step}, 'NowoDashboardMenuBundle') }}">
                        {{ 'dashboard.reindex_positions'|trans({'%step%': position_step}, 'NowoDashboardMenuBundle') }}
                    </button>
                </form>
                <form method="post" action="{{ path(dashboard_routes.items_check_parent_cycles|default('nowo_dashboard_menu_dashboard_items_check_parent_cycles'), { id: menu.id }) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('check_parent_cycles_' ~ menu.id) }}">
                    <button type="submit" class="btn btn-outline-secondary" title="{{ 'dashboard.check_parent_cycles_title'|trans({}, 'NowoDashboardMenuBundle') }}">
                        {{ 'dashboard.check_parent_cycles'|trans({}, 'NowoDashboardMenuBundle') }}
                    </button>
                </form>
            {% endif %}
            <button type="button" class="btn btn-primary btn-add-item" data-id="{{ menu.id }}" data-parent="" data-bs-toggle="modal" data-bs-target="#modal-item-form">{{ 'dashboard.add_item'|trans({}, 'NowoDashboardMenuBundle') }}</button>
        </div>
    </div>

    {% if menu.permissionChecker or menu.depthLimit is not null or menu.collapsible is not null or menu.collapsibleExpanded is not null or menu.nestedCollapsible is not null or menu.nestedCollapsibleSections is not null %}
        <div class="kit-admin-meta mb-2">
            {% if menu.permissionChecker %}<strong>{{ 'dashboard.permission_checker'|trans({}, 'NowoDashboardMenuBundle') }}:</strong> <code>{{ menu.permissionChecker }}</code>{% endif %}
            {% if menu.depthLimit is not null %} {% if menu.permissionChecker %}·{% endif %} <strong>{{ 'dashboard.depth_limit'|trans({}, 'NowoDashboardMenuBundle') }}:</strong> {{ menu.depthLimit }}{% endif %}
            {% if menu.collapsible is not null %} · <strong>{{ 'dashboard.collapsible'|trans({}, 'NowoDashboardMenuBundle') }}:</strong> {{ menu.collapsible ? 'dashboard.yes'|trans : 'dashboard.no'|trans({}, 'NowoDashboardMenuBundle') }}{% endif %}
            {% if menu.collapsibleExpanded is not null %} · <strong>{{ 'dashboard.collapsible_expanded'|trans({}, 'NowoDashboardMenuBundle') }}:</strong> {{ menu.collapsibleExpanded ? 'dashboard.yes'|trans : 'dashboard.no'|trans({}, 'NowoDashboardMenuBundle') }}{% endif %}
            {% if menu.nestedCollapsible is not null %} · <strong>{{ 'dashboard.nested_collapsible'|trans({}, 'NowoDashboardMenuBundle') }}:</strong> {{ menu.nestedCollapsible ? 'dashboard.yes'|trans : 'dashboard.no'|trans({}, 'NowoDashboardMenuBundle') }}{% endif %}
            {% if menu.nestedCollapsibleSections is not null %} · <strong>{{ 'form.menu_type.nested_collapsible_sections.label'|trans({}, 'NowoDashboardMenuBundle') }}:</strong> {{ menu.nestedCollapsibleSections ? 'dashboard.yes'|trans : 'dashboard.no'|trans({}, 'NowoDashboardMenuBundle') }}{% endif %}
        </div>
    {% endif %}
    {% if menu.ulId or menu.classMenu or menu.classItem or menu.classLink or menu.classChildren or menu.classSectionChildren or menu.classSectionChildItem or menu.classSectionChildLink or menu.classSectionLabel or menu.classSection or menu.classDivider or menu.classCurrent or menu.classBranchExpanded or menu.classHasChildren or menu.classExpanded or menu.classCollapsed %}
        <div class="kit-admin-meta mb-2">
            <strong>{{ 'dashboard.css_classes'|trans({}, 'NowoDashboardMenuBundle') }}</strong>: {% if menu.classMenu %}<code>menu: {{ menu.classMenu }}</code>{% endif %}
            {% if menu.ulId %}<code>ul_id: {{ menu.ulId }}</code>{% endif %}
            {% if menu.classItem %} <code>item: {{ menu.classItem }}</code>{% endif %}
            {% if menu.classLink %} <code>link: {{ menu.classLink }}</code>{% endif %}
            {% if menu.classChildren %} <code>children: {{ menu.classChildren }}</code>{% endif %}
            {% if menu.classSectionChildren %} <code>section-children: {{ menu.classSectionChildren }}</code>{% endif %}
            {% if menu.classSectionChildItem %} <code>section-child-item: {{ menu.classSectionChildItem }}</code>{% endif %}
            {% if menu.classSectionChildLink %} <code>section-child-link: {{ menu.classSectionChildLink }}</code>{% endif %}
            {% if menu.classSectionLabel %} <code>section-label: {{ menu.classSectionLabel }}</code>{% endif %}
            {% if menu.classSection %} <code>section: {{ menu.classSection }}</code>{% endif %}
            {% if menu.classDivider %} <code>divider: {{ menu.classDivider }}</code>{% endif %}
            {% if menu.classCurrent %} <code>current: {{ menu.classCurrent }}</code>{% endif %}
            {% if menu.classBranchExpanded %} <code>branch: {{ menu.classBranchExpanded }}</code>{% endif %}
            {% if menu.classHasChildren %} <code>has-children: {{ menu.classHasChildren }}</code>{% endif %}
            {% if menu.classExpanded %} <code>expanded: {{ menu.classExpanded }}</code>{% endif %}
            {% if menu.classCollapsed %} <code>collapsed: {{ menu.classCollapsed }}</code>{% endif %}
        </div>
    {% endif %}

    {% if items|length == 0 %}
        <p class="text-muted">{{ 'dashboard.no_items'|trans({}, 'NowoDashboardMenuBundle') }} <button type="button" class="btn btn-link p-0 align-baseline btn-add-item" data-id="{{ menu.id }}" data-parent="" data-bs-toggle="modal" data-bs-target="#modal-item-form">{{ 'dashboard.add_one'|trans({}, 'NowoDashboardMenuBundle') }}</button>.</p>
    {% else %}
        {% set currentLocale = app.request.locale|default('en') %}
        <style>
            /* Responsive item table: keep actions compact on narrow screens */
            .nowo-dashboard-menu-actions-col { width: 1%; white-space: nowrap; }
            .nowo-dashboard-menu-move-stack { display: inline-flex; flex-direction: column; gap: .25rem; }
            .nowo-dashboard-menu-actions { display: inline-flex; align-items: center; gap: .5rem; }
            .nowo-dashboard-menu-actions .btn { padding-left: .4rem; padding-right: .4rem; }
            .nowo-dashboard-menu-route { min-width: 18rem; }
            @media (max-width: 992px) {
                .nowo-dashboard-menu-route { min-width: 14rem; }
            }
        </style>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th class="nowo-dashboard-menu-actions-col">{{ 'dashboard.actions'|trans({}, 'NowoDashboardMenuBundle') }}</th>
                        <th style="width: 1%; white-space: nowrap;">{{ 'dashboard.parent'|trans({}, 'NowoDashboardMenuBundle') }}</th>
                        <th style="white-space: nowrap;">Label ({{ currentLocale }})</th>
                        <th class="nowo-dashboard-menu-route" style="white-space: nowrap;">{{ 'dashboard.route_url'|trans({}, 'NowoDashboardMenuBundle') }}</th>
                        <th>{{ 'dashboard.item'|trans({}, 'NowoDashboardMenuBundle') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in items %}
                        {% set depth = item_depths[item.id] is defined ? item_depths[item.id] : 0 %}
                        <tr id="item-{{ item.id }}">
                            <td class="nowo-dashboard-menu-actions-col">
                                <div class="nowo-dashboard-menu-actions">
                                    <div class="nowo-dashboard-menu-move-stack" aria-label="{{ 'dashboard.actions'|trans({}, 'NowoDashboardMenuBundle') }}">
                                        {% if prev_sibling[item.id] is defined and prev_sibling[item.id] is not null %}
                                            <form method="post" action="{{ path(dashboard_routes.item_move_up|default('nowo_dashboard_menu_dashboard_item_move_up'), { id: menu.id, itemId: item.id }) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('item_move_up_' ~ item.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="{{ 'dashboard.move_up'|trans({}, 'NowoDashboardMenuBundle') }}" aria-label="{{ 'dashboard.move_up'|trans({}, 'NowoDashboardMenuBundle') }}">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path fill-rule="evenodd" d="M8 3.5a.5.5 0 0 1 .354.146l4 4a.5.5 0 0 1-.708.708L8 4.707 4.354 8.354a.5.5 0 1 1-.708-.708l4-4A.5.5 0 0 1 8 3.5z"/></svg>
                                                </button>
                                            </form>
                                        {% else %}
                                            <span class="btn btn-sm btn-outline-secondary disabled" title="{{ 'dashboard.first'|trans({}, 'NowoDashboardMenuBundle') }}" aria-hidden="true">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path fill-rule="evenodd" d="M8 3.5a.5.5 0 0 1 .354.146l4 4a.5.5 0 0 1-.708.708L8 4.707 4.354 8.354a.5.5 0 1 1-.708-.708l4-4A.5.5 0 0 1 8 3.5z"/></svg>
                                            </span>
                                        {% endif %}
                                        {% if next_sibling[item.id] is defined and next_sibling[item.id] is not null %}
                                            <form method="post" action="{{ path(dashboard_routes.item_move_down|default('nowo_dashboard_menu_dashboard_item_move_down'), { id: menu.id, itemId: item.id }) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('item_move_down_' ~ item.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="{{ 'dashboard.move_down'|trans({}, 'NowoDashboardMenuBundle') }}" aria-label="{{ 'dashboard.move_down'|trans({}, 'NowoDashboardMenuBundle') }}">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path fill-rule="evenodd" d="M8 12.5a.5.5 0 0 1-.354-.146l-4-4a.5.5 0 1 1 .708-.708L8 11.293l3.646-3.647a.5.5 0 0 1 .708.708l-4 4A.5.5 0 0 1 8 12.5z"/></svg>
                                                </button>
                                            </form>
                                        {% else %}
                                            <span class="btn btn-sm btn-outline-secondary disabled" title="{{ 'dashboard.last'|trans({}, 'NowoDashboardMenuBundle') }}" aria-hidden="true">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path fill-rule="evenodd" d="M8 12.5a.5.5 0 0 1-.354-.146l-4-4a.5.5 0 1 1 .708-.708L8 11.293l3.646-3.647a.5.5 0 0 1 .708.708l-4 4A.5.5 0 0 1 8 12.5z"/></svg>
                                            </span>
                                        {% endif %}
                                    </div>
                                    <div class="d-inline-flex align-items-center gap-1">
                                        {% set can_have_children = item.itemType == 'link' or item.itemType == 'service' %}
                                        <button type="button" class="btn btn-sm btn-outline-success btn-add-item{% if not can_have_children %} disabled{% endif %}" title="{{ can_have_children ? 'dashboard.add_child'|trans({}, 'NowoDashboardMenuBundle') : 'dashboard.add_child_disabled'|trans({}, 'NowoDashboardMenuBundle') }}" aria-label="{{ 'dashboard.add_child'|trans({}, 'NowoDashboardMenuBundle') }}" {% if can_have_children %}data-id="{{ menu.id }}" data-parent="{{ item.id }}" data-bs-toggle="modal" data-bs-target="#modal-item-form"{% else %}disabled aria-disabled="true"{% endif %}>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 1a.5.5 0 0 1 .5.5V7.5H14.5a.5.5 0 0 1 0 1H8.5V14.5a.5.5 0 0 1-1 0V8.5H1.5a.5.5 0 0 1 0-1H7.5V1.5A.5.5 0 0 1 8 1z"/></svg>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-primary btn-edit-item" title="{{ 'dashboard.edit_labels'|trans({}, 'NowoDashboardMenuBundle') }}" aria-label="{{ 'dashboard.edit_labels'|trans({}, 'NowoDashboardMenuBundle') }}" data-id="{{ menu.id }}" data-item-id="{{ item.id }}" data-section="basic" data-bs-toggle="modal" data-bs-target="#modal-item-form">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/></svg>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-warning btn-edit-item" title="{{ 'dashboard.edit_type_position_icon'|trans({}, 'NowoDashboardMenuBundle') }}" aria-label="{{ 'dashboard.edit_type_position_icon'|trans({}, 'NowoDashboardMenuBundle') }}" data-id="{{ menu.id }}" data-item-id="{{ item.id }}" data-section="icon" data-bs-toggle="modal" data-bs-target="#modal-item-form">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M6.002 5.5a.5.5 0 0 1 .492-.41h.006a.5.5 0 0 1 .498.5v.5h2v-.5a.5.5 0 0 1 .498-.5h.006a.5.5 0 0 1 .492.41L11.5 10H4.5l1.502-4.5zM2.5 12a.5.5 0 0 0 .5.5h10a.5.5 0 0 0 .5-.5V10.5h-13V12z"/></svg>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary btn-edit-item btn-edit-item-config" title="{{ 'dashboard.edit_config'|trans({}, 'NowoDashboardMenuBundle') }}" aria-label="{{ 'dashboard.edit_config'|trans({}, 'NowoDashboardMenuBundle') }}" data-id="{{ menu.id }}" data-item-id="{{ item.id }}" data-section="config" data-bs-toggle="modal" data-bs-target="#modal-item-form">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/></svg>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger btn-delete-item" title="{{ 'dashboard.delete'|trans({}, 'NowoDashboardMenuBundle') }}" aria-label="{{ 'dashboard.delete'|trans({}, 'NowoDashboardMenuBundle') }}" data-id="{{ menu.id }}" data-item-id="{{ item.id }}" data-name="{{ item.getLabelForLocale(currentLocale) ?: ('dashboard.no_label'|trans({}, 'NowoDashboardMenuBundle')) }}" data-url="{{ path(dashboard_routes.item_delete|default('nowo_dashboard_menu_dashboard_item_delete'), { id: menu.id, itemId: item.id }) }}" data-token="{{ csrf_token('delete_item_' ~ item.id) }}" data-bs-toggle="modal" data-bs-target="#modal-delete-item-confirm">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/><path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/></svg>
                                        </button>
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted small">
                                <div>{{ item_parent_labels[item.id] is defined ? item_parent_labels[item.id] : '—' }}</div>
                                <div class="small text-secondary">Pos: {{ item.position }}</div>
                            </td>
                            <td class="small">
                                {% include '@NowoDashboardMenuBundle/dashboard/_dashboard_item_icon.html.twig' with { item: item } only %}
                                {{ item.getLabelForLocale(currentLocale) ?: ('dashboard.no_label'|trans({}, 'NowoDashboardMenuBundle')) }}
                            </td>
                            <td class="small">
                                {% if item.itemType == 'link' %}
                                    {% if item.linkType == 'route' and item.routeName %}
                                        {# Do not call dashboard_menu_href here: resolving the URL runs the router and flashes one error per row when params are missing. #}
                                        <code class="d-block text-muted">{{ item.routeName }}{% if item.routeParams and item.routeParams|length > 0 %} {{ item.routeParams|json_encode }}{% endif %}</code>
                                    {% elseif item.externalUrl %}
                                        <a href="{{ item.externalUrl }}" target="_blank" rel="noopener noreferrer" class="text-break">{{ item.externalUrl }}</a>
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                                {% set _permission_keys = item.permissionKeys ?? [] %}
                                <div class="mt-1">
                                    {% if _permission_keys is iterable and _permission_keys|length > 0 %}
                                        {% for permission_key in _permission_keys %}
                                            <code class="me-1">{{ permission_key }}</code>
                                        {% endfor %}
                                    {% else %}
                                        <span class="text-muted">No permission keys</span>
                                    {% endif %}
                                </div>
                                <div class="mt-1">
                                    {% if item.isUnanimous %}
                                        <span class="badge bg-success">Unanimous</span>
                                    {% else %}
                                        <span class="badge bg-warning text-dark">Non-unanimous</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td style="padding-left: {{ 0.5 + depth * 1.25 }}rem;">
                                {% include '@NowoDashboardMenuBundle/dashboard/_dashboard_item_icon.html.twig' with { item: item } only %}
                                <span class="badge bg-secondary me-2">{{ item.itemType }}</span>
                                {{ item.getLabelForLocale(currentLocale) ?: ('dashboard.no_label'|trans({}, 'NowoDashboardMenuBundle')) }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

