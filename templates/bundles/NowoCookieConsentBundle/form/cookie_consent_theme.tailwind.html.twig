{% use 'tailwind_2_layout.html.twig' %}

{% block checkbox_widget %}
    {% if form.parent is not null and (form.parent.vars.name == 'cookie_consent' or form.parent.vars.name == 'cookies') %}
        <input type="checkbox" {{ block('widget_attributes') }}{% if value is defined %} value="{{ value }}"{% endif %}{% if checked %} checked="checked"{% endif %} />
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block checkbox_row %}
    {% if form.parent is not null and form.parent.vars.name == 'cookie_consent' %}
        {% set is_required = name == 'required' %}
        {% set granular = nowo_cookie_consent_granular_cookie_selection() and not is_required %}
        {% set consent_form = form.parent %}
        <div class="nowo-cookie-consent__category nowo-cookie-consent__category--toggle{% if is_required %} nowo-cookie-consent__category--required{% endif %}{% if granular %} nowo-cookie-consent__category--granular{% endif %}" data-nowo-category="{{ name }}">
            <details class="nowo-cookie-consent__category-details">
                <summary class="nowo-cookie-consent__category-title-row">
                    <span class="nowo-cookie-consent__category-arrow" aria-hidden="true"></span>
                    <span class="nowo-cookie-consent__category-title">{{ ('nowo_cookie_consent.' ~ name ~ '.title')|trans({}, 'NowoCookieConsentBundle') }}</span>
                    {% if is_required %}
                        <span class="nowo-cookie-consent__category-badge">{{ 'nowo_cookie_consent.required.always_on'|trans({}, 'NowoCookieConsentBundle') }}</span>
                    {% endif %}
                    <span class="nowo-cookie-consent__toggle-wrapper" data-nowo-toggle data-nowo-category-toggle>
                        {{- form_widget(form, {attr: {class: 'nowo-cookie-consent__toggle-input'}}) -}}
                        <span class="nowo-cookie-consent__toggle-track" aria-hidden="true">
                            <span class="nowo-cookie-consent__toggle-knob">
                                <span class="nowo-cookie-consent__toggle-icon nowo-cookie-consent__toggle-icon--on">✓</span>
                                <span class="nowo-cookie-consent__toggle-icon nowo-cookie-consent__toggle-icon--off">✕</span>
                            </span>
                        </span>
                    </span>
                </summary>
                <div class="nowo-cookie-consent__category-desc-wrapper">
                    <p class="nowo-cookie-consent__category-description">{{ ('nowo_cookie_consent.' ~ name ~ '.description')|trans({}, 'NowoCookieConsentBundle') }}</p>
                    {% if granular %}
                        <p class="nowo-cookie-consent__granular-help">{{ 'nowo_cookie_consent.granular.help'|trans({}, 'NowoCookieConsentBundle') }}</p>
                    {% endif %}
                    {% set cookie_rows = nowo_cookie_consent_cookie_inventory()|filter(row => row.category == name) %}
                    {% include '@NowoCookieConsentBundle/_category_cookie_table.html.twig' with {
                        rows: cookie_rows,
                        consent_form: consent_form,
                        granular: granular,
                    } %}
                </div>
            </details>
        </div>
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block choice_row %}
    {% if form.parent is not null and form.parent.vars.name == 'cookie_consent' %}
        {{ block('checkbox_row') }}
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block submit_row %}
    {% if form.parent is not null and form.parent.vars.name == 'cookie_consent' %}
        {# Colors come from --nowo-cc-* (Beacon SCSS); keep BEM modifiers only. #}
        {%- set attr = attr|merge({class: (attr.class|default('') ~ ' nowo-cookie-consent__btn')|trim}) -%}
        {{ block('button_widget') }}
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}
