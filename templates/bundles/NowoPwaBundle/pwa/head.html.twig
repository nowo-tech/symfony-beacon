{# Override: no default pwa.css; theme-color follows site appearance accents. #}
{# REQ-TWIG-001: override via templates/bundles/NowoPwaBundle/pwa/head.html.twig #}
<link rel="manifest" href="{{ manifest_url }}">
{% set theme_light = site_appearance.accentColor|default(meta.theme_color_light|default(manifest.theme_color|default('#1f6f54'))) %}
{% set theme_dark = site_appearance.accentColorDark|default(meta.theme_color_dark|default(manifest.theme_color|default('#4aad7f'))) %}
<meta name="theme-color" content="{{ theme_light }}" media="(prefers-color-scheme: light)">
<meta name="theme-color" content="{{ theme_dark }}" media="(prefers-color-scheme: dark)">
{% if meta.color_scheme %}
<meta name="color-scheme" content="{{ meta.color_scheme }}">
{% endif %}
{% if meta.referrer %}
<meta name="referrer" content="{{ meta.referrer }}">
{% endif %}
{% set format_detection = meta.format_detection|default({}) %}
{% if format_detection.telephone is not null or format_detection.email is not null or format_detection.address is not null %}
<meta name="format-detection" content="telephone={{ format_detection.telephone|default(false) ? 'yes' : 'no' }}, email={{ format_detection.email|default(false) ? 'yes' : 'no' }}, address={{ format_detection.address|default(false) ? 'yes' : 'no' }}">
{% endif %}
{% if meta.mobile_web_app_capable|default(true) %}
<meta name="mobile-web-app-capable" content="yes">
{% endif %}
{% if meta.apple_mobile_web_app_capable|default(true) %}
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="{{ meta.apple_status_bar_style|default('default') }}">
<meta name="apple-mobile-web-app-title" content="{{ meta.apple_mobile_web_app_title|default(site_appearance.brandName|default(manifest.short_name|default('App'))) }}">
{% endif %}
{% if meta.viewport_fit %}
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit={{ meta.viewport_fit }}">
{% endif %}
{% if meta.msapplication_tile_color %}
<meta name="msapplication-TileColor" content="{{ meta.msapplication_tile_color }}">
{% endif %}
{% if meta.msapplication_tile_image %}
<meta name="msapplication-TileImage" content="{{ meta.msapplication_tile_image }}">
{% endif %}
{% if meta.msapplication_config %}
<meta name="msapplication-config" content="{{ meta.msapplication_config }}">
{% endif %}
{% for icon in meta.apple_touch_icons|default([]) %}
<link rel="apple-touch-icon"{% if icon.sizes|default('') %} sizes="{{ icon.sizes }}"{% endif %} href="{{ icon.href }}">
{% else %}
{% for icon in manifest.icons|default([]) %}
<link rel="icon" type="{{ icon.type|default('image/png') }}" sizes="{{ icon.sizes|default('192x192') }}" href="{{ icon.src }}">
{% if loop.first %}
<link rel="apple-touch-icon" href="{{ icon.src }}">
{% endif %}
{% endfor %}
{% endfor %}
{% for image in meta.apple_startup_images|default([]) %}
<link rel="apple-touch-startup-image" href="{{ image.href }}"{% if image.media|default('') %} media="{{ image.media }}"{% endif %}>
{% endfor %}
{% if meta.mask_icon.href|default('') %}
<link rel="mask-icon" href="{{ meta.mask_icon.href }}" color="{{ meta.mask_icon.color|default(theme_light) }}">
{% endif %}
{% for tag in meta.extra_link_tags|default([]) %}
<link rel="{{ tag.rel }}" href="{{ tag.href }}"{% if tag.type|default('') %} type="{{ tag.type }}"{% endif %}{% if tag.sizes|default('') %} sizes="{{ tag.sizes }}"{% endif %}>
{% endfor %}
{% if service_worker.enabled|default(true) and client.register_on_load|default(true) %}
<script type="module" src="{{ asset('pwa.js', 'nowo_pwa') }}"
        data-pwa-sw-url="{{ service_worker_url }}"
        data-pwa-scope="{{ service_worker.scope|default('/') }}"
        data-pwa-check-updates="{{ client.check_updates_on_visibility|default(true) ? '1' : '0' }}"
        data-pwa-reload-on-update="{{ client.reload_on_update|default(false) ? '1' : '0' }}"></script>
{% endif %}
