<!DOCTYPE html>
<html lang="{{ app.request.locale|default(manifest.lang|default('en')) }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ 'offline.title'|trans({}, 'NowoPwaBundle') }} — {{ site_appearance.brandName|default(manifest_name) }}</title>
    <style>
        :root {
            --beacon-ink: #0f1c18;
            --beacon-paper: #f3f6f4;
            --beacon-moss: #1f6f54;
            --beacon-surface: #ffffff;
            --beacon-sand: #d8e2dc;
        }
        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 2rem;
            font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
            background: var(--beacon-paper);
            color: var(--beacon-ink);
            text-align: center;
        }
        .eyebrow {
            margin: 0 0 0.75rem;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.22em;
            text-transform: uppercase;
            color: var(--beacon-moss);
        }
        h1 {
            margin: 0;
            font-family: "Source Serif 4 Variable", "Source Serif 4", Georgia, serif;
            font-size: 1.75rem;
        }
        p {
            margin: 0.75rem auto 0;
            max-width: 28rem;
            color: color-mix(in srgb, var(--beacon-ink) 65%, transparent);
        }
        a {
            display: inline-flex;
            margin-top: 1.5rem;
            padding: 0.625rem 1rem;
            border-radius: 0.375rem;
            background: var(--beacon-moss);
            color: #fff;
            font-weight: 600;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div>
        <img src="{{ asset('brand/beacon-mark.svg') }}" alt="" width="40" height="47" style="display:block;margin:0 auto 1rem">
        <p class="eyebrow">{{ site_appearance.brandName|default(manifest_name) }}</p>
        <h1>{{ 'offline.heading'|trans({}, 'NowoPwaBundle') }}</h1>
        <p>{{ 'offline.body'|trans({}, 'NowoPwaBundle') }}</p>
        <p><a href="{{ path('nowo_auth_kit_login', {_locale: app.request.locale|default('en')}) }}">{{ 'offline.retry'|trans({}, 'NowoPwaBundle') }}</a></p>
    </div>
</body>
</html>
