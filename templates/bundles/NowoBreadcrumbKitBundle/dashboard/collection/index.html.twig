{% extends '@NowoBreadcrumbKitBundle/dashboard/base.html.twig' %}
{% trans_default_domain 'NowoBreadcrumbKitBundle' %}
{% import '@NowoBreadcrumbKitBundle/dashboard/_icons.html.twig' as bk_icon %}

{% block title %}{{ 'dashboard.collections_heading'|trans }}{% endblock %}

{% block breadcrumb_kit_body %}
    <div class="d-flex flex-wrap align-items-center gap-1 mb-2">
        <form method="get" action="{{ path(dashboard_routes.index|default('nowo_breadcrumb_kit_dashboard_collections_index')) }}" class="d-flex gap-1 flex-grow-1" role="search">
            <input type="search" name="q" value="{{ search|e('html_attr') }}" class="form-control" placeholder="{{ 'dashboard.search_placeholder'|trans }}" aria-label="{{ 'dashboard.search'|trans }}" style="max-width: 20rem;">
            <button type="submit" class="btn btn-outline-secondary">{{ 'dashboard.search'|trans }}</button>
            {% if search is not empty %}
                <a href="{{ path(dashboard_routes.index|default('nowo_breadcrumb_kit_dashboard_collections_index')) }}" class="btn btn-outline-secondary">{{ 'dashboard.clear'|trans }}</a>
            {% endif %}
        </form>
        <a href="{{ path(dashboard_routes.export_all|default('nowo_breadcrumb_kit_dashboard_export_all')) }}" class="btn btn-outline-secondary" target="_blank" rel="noopener noreferrer">{{ 'dashboard.export_all'|trans }}</a>
        <button type="button" class="btn btn-outline-secondary btn-bk-import" data-bs-toggle="modal" data-bs-target="#modal-bk-import" data-bk-import-url="{{ path(dashboard_routes.import|default('nowo_breadcrumb_kit_dashboard_import')) }}?_partial=1">{{ 'dashboard.import'|trans }}</button>
        <button type="button" class="btn btn-primary btn-bk-collection-form" data-bs-toggle="modal" data-bs-target="#modal-bk-collection-form" data-bk-url="{{ path(dashboard_routes.new|default('nowo_breadcrumb_kit_dashboard_collections_new')) }}?_partial=1" data-bk-title="{{ 'dashboard.new_collection_modal_title'|trans|e('html_attr') }}">{{ 'dashboard.new_collection'|trans }}</button>
    </div>

    {% if collections is empty %}
        <p class="text-muted">{{ 'dashboard.empty_collections'|trans }}</p>
    {% else %}
        <ul class="list-group m-0">
            {% for c in collections %}
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <strong>{{ c.code }}</strong>
                        {% set _itemsCount = collection_item_counts[c.id]|default(0) %}
                        <span class="badge bg-light text-dark border ms-2" title="{{ _itemsCount }}">{{ _itemsCount }}</span>
                        {% if c.name %}<span class="text-muted"> — {{ c.name }}</span>{% endif %}
                        {% if c.contextKey is not empty %}
                            <br><span class="small text-muted">{{ 'dashboard.context'|trans }}: {{ c.contextKey }}</span>
                        {% endif %}
                    </div>
                    <div class="d-flex gap-1">
                        <a href="{{ path('nowo_breadcrumb_kit_dashboard_items_index', {collectionId: c.id}) }}" class="btn btn-sm btn-outline-primary" title="{{ 'dashboard.link_items'|trans }}" aria-label="{{ 'dashboard.link_items'|trans }}">{{ bk_icon.items() }}</a>
                        <a href="{{ path(dashboard_routes.export|default('nowo_breadcrumb_kit_dashboard_collections_export'), {id: c.id}) }}" class="btn btn-sm btn-outline-secondary" target="_blank" rel="noopener noreferrer" title="{{ 'dashboard.link_export_json'|trans }}" aria-label="{{ 'dashboard.link_export_json'|trans }}">{{ bk_icon.export_json() }}</a>
                        <button type="button" class="btn btn-sm btn-outline-primary btn-bk-collection-form" data-bs-toggle="modal" data-bs-target="#modal-bk-collection-form" data-bk-url="{{ path(dashboard_routes.edit|default('nowo_breadcrumb_kit_dashboard_collections_edit'), {id: c.id}) }}?_partial=1" data-bk-title="{{ 'dashboard.edit_collection_modal_title'|trans({'%code%': c.code})|e('html_attr') }}" title="{{ 'dashboard.link_edit'|trans }}" aria-label="{{ 'dashboard.link_edit'|trans }}">{{ bk_icon.edit() }}</button>
                        <button type="button" class="btn btn-sm btn-outline-danger btn-bk-delete" data-id="{{ c.id }}" data-name="{{ c.code }}{% if c.name %} — {{ c.name }}{% endif %}" data-url="{{ path(dashboard_routes.delete|default('nowo_breadcrumb_kit_dashboard_collections_delete'), {id: c.id}) }}" data-token="{{ csrf_token('delete_collection_' ~ c.id) }}" data-bs-toggle="modal" data-bs-target="#modal-bk-delete" title="{{ 'dashboard.delete'|trans }}" aria-label="{{ 'dashboard.delete'|trans }}">{{ bk_icon.trash() }}</button>
                    </div>
                </li>
            {% endfor %}
        </ul>
        {% if pagination is not null and pagination.total_pages > 1 %}
            <nav aria-label="{{ 'dashboard.pagination_collections'|trans }}" class="mt-3">
                <ul class="pagination pagination-sm flex-wrap">
                    {% set indexRoute = dashboard_routes.index|default('nowo_breadcrumb_kit_dashboard_collections_index') %}
                    {% set queryParams = search is not empty ? {q: search} : {} %}
                    <li class="page-item{% if pagination.current_page <= 1 %} disabled{% endif %}">
                        <a class="page-link" href="{% if pagination.current_page > 1 %}{{ path(indexRoute, queryParams|merge({page: pagination.current_page - 1})) }}{% else %}#{% endif %}" aria-label="{{ 'dashboard.previous'|trans }}">«</a>
                    </li>
                    {% for p in 1..pagination.total_pages %}
                        <li class="page-item{% if p == pagination.current_page %} active{% endif %}">
                            <a class="page-link" href="{{ path(indexRoute, queryParams|merge({page: p})) }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                    <li class="page-item{% if pagination.current_page >= pagination.total_pages %} disabled{% endif %}">
                        <a class="page-link" href="{% if pagination.current_page < pagination.total_pages %}{{ path(indexRoute, queryParams|merge({page: pagination.current_page + 1})) }}{% else %}#{% endif %}" aria-label="{{ 'dashboard.next'|trans }}">»</a>
                    </li>
                </ul>
                <p class="small text-muted mt-1">
                    {% set from = collections|length > 0 ? (pagination.current_page - 1) * pagination.per_page + 1 : 0 %}
                    {% set to = (pagination.current_page - 1) * pagination.per_page + collections|length %}
                    {{ 'dashboard.showing_from_to_of_total'|trans({'%from%': from, '%to%': to, '%total%': pagination.total}) }}
                </p>
            </nav>
        {% endif %}
    {% endif %}
{% endblock %}

{% block dashboard_scripts %}
<script>
window.__breadcrumbKitDashboard = Object.assign({}, window.__breadcrumbKitDashboard || {}, { page: 'collections_index' });
</script>
{% endblock %}
