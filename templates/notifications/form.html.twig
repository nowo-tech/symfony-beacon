{% extends 'base.html.twig' %}

{% block title %}{{ (is_edit ? 'notifications.edit_title' : 'notifications.new_title')|trans }} — {{ project.name }}{% endblock %}

{% block body %}
{% include 'project/_nav.html.twig' with {project: project, current: 'settings'} %}

<h1 class="mb-2 text-2xl font-semibold">{{ (is_edit ? 'notifications.edit_title' : 'notifications.new_title')|trans }}</h1>
<p class="mb-6 text-sm text-[var(--color-ink)]/65">
    {{ 'notifications.form_help'|trans }}
    <a href="{{ path('project_notification_help', {id: project.uuid}) }}">{{ 'notifications.help.link'|trans }}</a>
</p>

{{ form_start(form, {attr: {class: 'panel notification-destination-form max-w-xl space-y-4'}}) }}
    {{ form_row(form.label) }}
    {{ form_row(form.type) }}
    {{ form_row(form.endpointUrl) }}
    {{ form_row(form.enabled) }}
    {{ form_row(form.categories) }}
    <fieldset class="space-y-3 border-t border-[var(--color-sand)] pt-4">
        <legend class="text-sm font-semibold">{{ 'notifications.form.quiet_hours_legend'|trans }}</legend>
        <p class="text-xs text-[var(--color-ink)]/55">{{ 'notifications.form.pagerduty_note'|trans }}</p>
        {{ form_row(form.quietHoursEnabled) }}
        {{ form_row(form.quietHoursTimezone) }}
        <div class="grid gap-3 sm:grid-cols-2">
            {{ form_row(form.quietHoursStart) }}
            {{ form_row(form.quietHoursEnd) }}
        </div>
        {{ form_row(form.digestEnabled) }}
    </fieldset>
    <div class="flex flex-wrap gap-2 pt-2">
        <button class="btn-primary" type="submit">{{ 'notifications.save'|trans }}</button>
        <a class="btn-ghost" href="{{ path('project_settings', {id: project.uuid}) }}">{{ 'notifications.cancel'|trans }}</a>
    </div>
{{ form_end(form) }}
{% endblock %}
