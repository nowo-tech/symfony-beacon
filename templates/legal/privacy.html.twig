{% extends 'legal/layout.html.twig' %}

{% block title %}{{ 'legal.privacy.title'|trans }} — {{ site_appearance.brandName }}{% endblock %}

{% block legal_body %}
<article class="legal-doc prose-legal">
    <h1>{{ 'legal.privacy.title'|trans }}</h1>
    <p class="legal-doc__meta">{{ 'legal.last_updated'|trans({'%date%': '2026-07-20'}) }}</p>

    <p>{{ 'legal.privacy.intro'|trans({'%brand%': site_appearance.brandName}) }}</p>

    <h2>{{ 'legal.privacy.controller_heading'|trans }}</h2>
    <p>{{ 'legal.privacy.controller_body'|trans }}</p>

    <h2>{{ 'legal.privacy.data_heading'|trans }}</h2>
    <p>{{ 'legal.privacy.data_body'|trans }}</p>
    <ul>
        <li>{{ 'legal.privacy.data_account'|trans }}</li>
        <li>{{ 'legal.privacy.data_telemetry'|trans }}</li>
        <li>{{ 'legal.privacy.data_logs'|trans }}</li>
        <li>{{ 'legal.privacy.data_cookies'|trans }}</li>
    </ul>

    <h2>{{ 'legal.privacy.purpose_heading'|trans }}</h2>
    <p>{{ 'legal.privacy.purpose_body'|trans }}</p>

    <h2>{{ 'legal.privacy.retention_heading'|trans }}</h2>
    <p>{{ 'legal.privacy.retention_body'|trans }}</p>

    <h2>{{ 'legal.privacy.rights_heading'|trans }}</h2>
    <p>{{ 'legal.privacy.rights_body'|trans }}</p>

    <h2>{{ 'legal.privacy.cookies_heading'|trans }}</h2>
    <p>{{ 'legal.privacy.cookies_body'|trans }}</p>
    <p>
        <a href="{{ path('legal_cookies', {_locale: app.request.locale|default(default_locale)}) }}">{{ 'legal.cookies.title'|trans }}</a>
        ·
        <a href="#" data-nowo-open-consent>{{ 'legal.manage_cookies'|trans }}</a>
    </p>

    <nav class="legal-doc__nav" aria-label="{{ 'legal.nav.label'|trans }}">
        <a href="{{ path('legal_notice', {_locale: app.request.locale|default(default_locale)}) }}">{{ 'legal.notice.title'|trans }}</a>
        <a href="{{ path('legal_terms', {_locale: app.request.locale|default(default_locale)}) }}">{{ 'legal.terms.title'|trans }}</a>
        <a href="{{ path('legal_cookies', {_locale: app.request.locale|default(default_locale)}) }}">{{ 'legal.cookies.title'|trans }}</a>
    </nav>
</article>
{% endblock %}
