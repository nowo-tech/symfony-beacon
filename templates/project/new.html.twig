{% extends 'base.html.twig' %}

{% block title %}{{ 'project.new.title'|trans }} — {{ site_appearance.brandName }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-lg">
    <h1 class="mb-6 font-[family-name:var(--font-display)] text-3xl font-bold">{{ 'project.new.title'|trans }}</h1>
    {{ form_start(form, {attr: {class: 'panel space-y-4'}}) }}
        {{ form_row(form.name) }}
        {{ form_row(form.description) }}
        <button class="btn-primary" type="submit">{{ 'project.new.submit'|trans }}</button>
    {{ form_end(form) }}
</div>
{% endblock %}
