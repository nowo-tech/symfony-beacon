{% extends 'base.html.twig' %}

{% block title %}{{ 'project.settings.title'|trans }} — {{ project.name }}{% endblock %}

{% block body %}
{% include 'project/_nav.html.twig' with {project: project, current: 'settings'} %}

<p class="mb-6 text-sm text-[var(--color-ink)]/65">{{ 'project.settings.intro'|trans }}</p>

{% if not project.ingestEnabled %}
    <div class="mb-6 rounded-md border border-[var(--color-alert)] bg-[var(--color-alert)]/10 px-4 py-3 text-sm text-[var(--color-alert)]" role="status">
        {{ 'project.governance.ingest_disabled_banner'|trans }}
    </div>
{% endif %}

{% if membership.role.value in ['owner', 'admin'] %}
<section class="panel mb-6">
    <h2 class="mb-2 text-lg font-semibold">{{ 'project.governance.title'|trans }}</h2>
    <p class="mb-4 text-sm text-[var(--color-ink)]/60">{{ 'project.governance.help'|trans }}</p>
    {% if effectiveQuota > 0 %}
        <p class="mb-4 text-xs text-[var(--color-ink)]/55">
            {{ 'project.governance.quota_usage'|trans({'%count%': eventsToday, '%quota%': effectiveQuota}) }}
        </p>
    {% endif %}
    <form method="post" action="{{ path('project_governance_save', {id: project.uuid}) }}" class="grid gap-4 sm:grid-cols-2">
        <input type="hidden" name="_token" value="{{ csrf_token('project_governance_' ~ project.id) }}">
        <div>
            <label class="mb-1 block text-sm font-medium" for="retention_days">{{ 'project.governance.retention_days'|trans }}</label>
            <input class="input w-full" type="number" min="0" name="retention_days" id="retention_days" value="{{ project.retentionDays ?? '' }}" placeholder="{{ governanceDefaults.retention_days }}">
            <p class="mt-1 text-xs text-[var(--color-ink)]/50">{{ 'project.governance.inherit_hint'|trans({'%default%': governanceDefaults.retention_days}) }}</p>
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium" for="retention_max_events">{{ 'project.governance.retention_max_events'|trans }}</label>
            <input class="input w-full" type="number" min="0" name="retention_max_events" id="retention_max_events" value="{{ project.retentionMaxEvents ?? '' }}" placeholder="{{ governanceDefaults.retention_max_events }}">
            <p class="mt-1 text-xs text-[var(--color-ink)]/50">{{ 'project.governance.inherit_hint'|trans({'%default%': governanceDefaults.retention_max_events}) }}</p>
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium" for="ingest_rate_limit_per_minute">{{ 'project.governance.ingest_rate_limit'|trans }}</label>
            <input class="input w-full" type="number" min="0" name="ingest_rate_limit_per_minute" id="ingest_rate_limit_per_minute" value="{{ project.ingestRateLimitPerMinute ?? '' }}" placeholder="{{ governanceDefaults.ingest_rate_limit }}">
            <p class="mt-1 text-xs text-[var(--color-ink)]/50">{{ 'project.governance.inherit_hint'|trans({'%default%': governanceDefaults.ingest_rate_limit}) }}</p>
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium" for="event_quota_daily">{{ 'project.governance.event_quota_daily'|trans }}</label>
            <input class="input w-full" type="number" min="0" name="event_quota_daily" id="event_quota_daily" value="{{ project.eventQuotaDaily ?? '' }}" placeholder="{{ governanceDefaults.event_quota_daily }}">
            <p class="mt-1 text-xs text-[var(--color-ink)]/50">{{ 'project.governance.inherit_hint'|trans({'%default%': governanceDefaults.event_quota_daily}) }}</p>
        </div>
        <div class="sm:col-span-2">
            <button class="btn-primary" type="submit">{{ 'project.governance.save'|trans }}</button>
        </div>
    </form>
</section>
{% endif %}

<div class="grid gap-6 lg:grid-cols-2">
    <section class="panel">
        <h2 class="mb-3 text-lg font-semibold">{{ 'project.api_keys.title'|trans }}</h2>
        <p class="mb-3 text-sm text-[var(--color-ink)]/60">{{ 'project.api_keys.help'|trans }}</p>
        <ul class="space-y-3">
            {% for key in project.apiKeys %}
                <li class="rounded-md border border-[var(--color-sand)] bg-[var(--color-paper)] p-3 text-sm">
                    <div class="font-medium">{{ key.label }} {% if not key.active %}<span class="badge badge-error">{{ 'project.api_keys.inactive'|trans }}</span>{% endif %}</div>
                    <code class="mt-2 block break-all text-xs">{{ key.buildDsn(baseUrl) }}</code>
                    <div class="mt-1 text-xs text-[var(--color-ink)]/55">{{ 'project.api_keys.public'|trans }} {{ key.publicKey }}</div>
                    {% if membership.role.value in ['owner', 'admin'] and key.active %}
                        <div class="mt-3 flex flex-wrap gap-2">
                            <form method="post" action="{{ path('project_keys_rotate', {projectId: project.uuid, keyId: key.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('project_key_rotate_' ~ key.id) }}">
                                <button class="btn-ghost btn-sm" type="submit">{{ 'project.api_keys.rotate'|trans }}</button>
                            </form>
                            <form method="post" action="{{ path('project_keys_revoke', {projectId: project.uuid, keyId: key.id}) }}" onsubmit="return confirm('{{ 'project.api_keys.revoke_confirm'|trans|e('js') }}')">
                                <input type="hidden" name="_token" value="{{ csrf_token('project_key_revoke_' ~ key.id) }}">
                                <button class="btn-ghost btn-sm" type="submit">{{ 'project.api_keys.revoke'|trans }}</button>
                            </form>
                        </div>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
        {% if membership.role.value in ['owner', 'admin'] %}
            <form
                method="post"
                action="{{ path('project_keys_create', {id: project.uuid}) }}"
                class="mt-4 flex flex-wrap gap-2"
                data-controller="human-key-label"
                data-human-key-label-adjectives-value="{{ labelAdjectives|json_encode|e('html_attr') }}"
                data-human-key-label-nouns-value="{{ labelNouns|json_encode|e('html_attr') }}"
            >
                <input type="hidden" name="_token" value="{{ csrf_token('project_key_create_' ~ project.id) }}">
                <input
                    class="input min-w-40 flex-1"
                    name="label"
                    placeholder="{{ 'project.api_keys.label_placeholder'|trans }}"
                    value="{{ suggestedLabel }}"
                    data-human-key-label-target="label"
                    autocomplete="off"
                >
                <button
                    type="button"
                    class="btn-ghost"
                    data-action="human-key-label#generate"
                    title="{{ 'project.api_keys.generate_hint'|trans }}"
                >{{ 'project.api_keys.generate'|trans }}</button>
                <button class="btn-primary" type="submit">{{ 'project.api_keys.add'|trans }}</button>
            </form>
        {% endif %}
    </section>

    <section class="panel">
        <div class="mb-3 flex flex-wrap items-start justify-between gap-2">
            <div>
                <h2 class="text-lg font-semibold">{{ 'project.members.title'|trans }}</h2>
                <p class="mt-1 text-sm text-[var(--color-ink)]/60">{{ 'project.members.help'|trans }}</p>
            </div>
            {% if assignableRoles is not empty %}
                <div data-controller="confirm-dialog">
                    <button
                        type="button"
                        class="btn-primary btn-sm btn-icon"
                        data-action="confirm-dialog#open"
                        title="{{ 'project.members.add'|trans }}"
                        aria-label="{{ 'project.members.add'|trans }}"
                    >
                        <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                        </svg>
                    </button>
                    <dialog
                        class="confirm-dialog confirm-dialog--form"
                        data-confirm-dialog-target="dialog">

                        <form
                            method="post"
                            action="{{ path('project_members_add', {id: project.uuid}) }}"
                            class="confirm-dialog__panel"
                        >
                            <h3 class="confirm-dialog__title">{{ 'project.members.add_title'|trans }}</h3>
                            <p class="confirm-dialog__body">{{ 'project.members.add_help'|trans }}</p>
                            <input type="hidden" name="_token" value="{{ csrf_token('project_member_add_' ~ project.id) }}">
                            <label class="confirm-dialog__label" for="member-email">{{ 'project.members.email_label'|trans }}</label>
                            <input
                                id="member-email"
                                class="input w-full"
                                type="email"
                                name="email"
                                required
                                autocomplete="off"
                                placeholder="{{ 'project.members.email_placeholder'|trans }}"
                            >
                            <label class="confirm-dialog__label mt-3" for="member-add-role">{{ 'project.members.role_label'|trans }}</label>
                            <select id="member-add-role" class="input w-full" name="role">
                                {% for role in assignableRoles %}
                                    <option value="{{ role.value }}" {% if role.value == 'member' %}selected{% endif %}>{{ ('project.members.role.' ~ role.value)|trans }}</option>
                                {% endfor %}
                            </select>
                            <div class="confirm-dialog__actions">
                                <button type="button" class="btn-ghost" data-confirm-dialog-close>{{ 'project.danger.cancel'|trans }}</button>
                                <button class="btn-primary" type="submit">{{ 'project.members.add'|trans }}</button>
                            </div>
                        </form>
                    </dialog>
                </div>
            {% endif %}
        </div>
        <ul class="space-y-3 text-sm">
            {% for member in project.memberships %}
                {% set memberUser = member.user %}
                {% set isLastOwner = member.role.value == 'owner' and ownerCount <= 1 %}
                {% set actorIsOwner = membership.role.value == 'owner' %}
                {% set canManageThis = assignableRoles is not empty
                    and (actorIsOwner or member.role.value != 'owner') %}
                <li class="rounded-md border border-[var(--color-sand)] bg-[var(--color-paper)] p-3">
                    <div class="flex flex-wrap items-start justify-between gap-3">
                        <div class="min-w-0">
                            <div class="font-medium">{{ memberUser.displayName }}</div>
                            <div class="text-xs text-[var(--color-ink)]/60">{{ memberUser.email }}</div>
                            <div class="mt-1">
                                <span class="badge bg-[var(--color-sand)]">{{ ('project.members.role.' ~ member.role.value)|trans }}</span>
                            </div>
                        </div>
                        {% if canManageThis %}
                            <div class="flex shrink-0 items-center gap-1">
                                <div data-controller="confirm-dialog">
                                    <button
                                        type="button"
                                        class="btn-ghost btn-sm btn-icon"
                                        data-action="confirm-dialog#open"
                                        title="{{ 'project.members.edit_role'|trans }}"
                                        aria-label="{{ 'project.members.edit_role'|trans }}"
                                    >
                                        <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                            <path fill="currentColor" d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm2.92 2.83H5v-.92l9.06-9.06.92.92L5.92 20.08zM20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                        </svg>
                                    </button>
                                    <dialog
                                        class="confirm-dialog confirm-dialog--form"
                                        data-confirm-dialog-target="dialog">

                                        <form
                                            method="post"
                                            action="{{ path('project_members_role', {projectId: project.uuid, userId: memberUser.uuid}) }}"
                                            class="confirm-dialog__panel"
                                        >
                                            <h3 class="confirm-dialog__title">{{ 'project.members.edit_role_title'|trans }}</h3>
                                            <p class="confirm-dialog__body">{{ 'project.members.edit_role_body'|trans({'%name%': memberUser.displayName, '%email%': memberUser.email}) }}</p>
                                            {% if isLastOwner %}
                                                <p class="confirm-dialog__body">{{ 'project.members.last_owner_hint'|trans }}</p>
                                            {% endif %}
                                            <input type="hidden" name="_token" value="{{ csrf_token('project_member_role_' ~ member.id) }}">
                                            <label class="confirm-dialog__label" for="member-role-{{ member.id }}">{{ 'project.members.role_label'|trans }}</label>
                                            <select
                                                id="member-role-{{ member.id }}"
                                                class="input w-full"
                                                name="role"
                                                {% if isLastOwner %}disabled{% endif %}
                                            >
                                                {% for role in assignableRoles %}
                                                    <option value="{{ role.value }}" {% if member.role == role %}selected{% endif %}>{{ ('project.members.role.' ~ role.value)|trans }}</option>
                                                {% endfor %}
                                                {% if member.role.value == 'owner' and not actorIsOwner %}
                                                    <option value="owner" selected>{{ 'project.members.role.owner'|trans }}</option>
                                                {% endif %}
                                            </select>
                                            <div class="confirm-dialog__actions">
                                                <button type="button" class="btn-ghost" data-confirm-dialog-close>{{ 'project.danger.cancel'|trans }}</button>
                                                <button class="btn-primary" type="submit" {% if isLastOwner %}disabled{% endif %}>{{ 'project.members.update_role'|trans }}</button>
                                            </div>
                                        </form>
                                    </dialog>
                                </div>

                                <div data-controller="confirm-dialog">
                                    <button
                                        type="button"
                                        class="btn-ghost btn-sm btn-icon"
                                        data-action="confirm-dialog#open"
                                        title="{{ 'project.members.remove'|trans }}"
                                        aria-label="{{ 'project.members.remove'|trans }}"
                                    >
                                        <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                            <path fill="currentColor" d="M6 19a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                                        </svg>
                                    </button>
                                    <dialog
                                        class="confirm-dialog confirm-dialog--form"
                                        data-confirm-dialog-target="dialog">

                                        <form
                                            method="post"
                                            action="{{ path('project_members_remove', {projectId: project.uuid, userId: memberUser.uuid}) }}"
                                            class="confirm-dialog__panel"
                                        >
                                            <h3 class="confirm-dialog__title">{{ 'project.members.remove_title'|trans }}</h3>
                                            {% if isLastOwner %}
                                                <p class="confirm-dialog__body">{{ 'project.members.last_owner_hint'|trans }}</p>
                                            {% else %}
                                                <p class="confirm-dialog__body">{{ 'project.members.remove_confirm'|trans({'%email%': memberUser.email}) }}</p>
                                            {% endif %}
                                            <input type="hidden" name="_token" value="{{ csrf_token('project_member_remove_' ~ member.id) }}">
                                            <div class="confirm-dialog__actions">
                                                <button type="button" class="btn-ghost" data-confirm-dialog-close>{{ 'project.danger.cancel'|trans }}</button>
                                                <button class="btn-danger" type="submit" {% if isLastOwner %}disabled{% endif %}>{{ 'project.members.remove'|trans }}</button>
                                            </div>
                                        </form>
                                    </dialog>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>
        <p class="mt-3 text-xs text-[var(--color-ink)]/55">{{ 'project.members.your_role'|trans }} {{ ('project.members.role.' ~ membership.role.value)|trans }}</p>
    </section>
</div>

<section class="panel mt-6">
    <h2 class="mb-3 text-lg font-semibold">{{ 'project.groups.title'|trans }}</h2>
    <p class="mb-3 text-sm text-[var(--color-ink)]/60">{{ 'project.groups.help'|trans }}</p>
    <ul class="space-y-3 text-sm">
        {% for groupAccess in project.groupAccesses %}
            {% set linkedGroup = groupAccess.userGroup %}
            <li class="rounded-md border border-[var(--color-sand)] bg-[var(--color-paper)] p-3">
                <div class="flex flex-wrap items-start justify-between gap-3">
                    <div class="min-w-0">
                        <div class="font-medium">{{ linkedGroup.name }}</div>
                        <div class="text-xs text-[var(--color-ink)]/60">{{ 'project.groups.member_count'|trans({'%count%': linkedGroup.memberships|length}) }}</div>
                        <div class="mt-1">
                            <span class="badge bg-[var(--color-sand)]">{{ ('project.members.role.' ~ groupAccess.role.value)|trans }}</span>
                        </div>
                    </div>
                    {% if assignableGroupRoles is not empty %}
                        <div class="flex shrink-0 items-center gap-1">
                            <div data-controller="confirm-dialog">
                                <button
                                    type="button"
                                    class="btn-ghost btn-sm btn-icon"
                                    data-action="confirm-dialog#open"
                                    title="{{ 'project.groups.edit_role'|trans }}"
                                    aria-label="{{ 'project.groups.edit_role'|trans }}"
                                >
                                    <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                        <path fill="currentColor" d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm2.92 2.83H5v-.92l9.06-9.06.92.92L5.92 20.08zM20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                                    </svg>
                                </button>
                                <dialog
                                    class="confirm-dialog confirm-dialog--form"
                                    data-confirm-dialog-target="dialog">

                                    <form
                                        method="post"
                                        action="{{ path('project_groups_role', {projectId: project.uuid, groupAccessId: groupAccess.uuid}) }}"
                                        class="confirm-dialog__panel"
                                    >
                                        <h3 class="confirm-dialog__title">{{ 'project.groups.edit_role_title'|trans }}</h3>
                                        <p class="confirm-dialog__body">{{ 'project.groups.edit_role_body'|trans({'%name%': linkedGroup.name}) }}</p>
                                        <input type="hidden" name="_token" value="{{ csrf_token('project_group_role_' ~ groupAccess.id) }}">
                                        <label class="confirm-dialog__label" for="group-role-{{ groupAccess.id }}">{{ 'project.members.role_label'|trans }}</label>
                                        <select id="group-role-{{ groupAccess.id }}" class="input w-full" name="role">
                                            {% for role in assignableGroupRoles %}
                                                <option value="{{ role.value }}" {% if groupAccess.role == role %}selected{% endif %}>{{ ('project.members.role.' ~ role.value)|trans }}</option>
                                            {% endfor %}
                                        </select>
                                        <div class="confirm-dialog__actions">
                                            <button type="button" class="btn-ghost" data-confirm-dialog-close>{{ 'project.danger.cancel'|trans }}</button>
                                            <button class="btn-primary" type="submit">{{ 'project.members.update_role'|trans }}</button>
                                        </div>
                                    </form>
                                </dialog>
                            </div>

                            <div data-controller="confirm-dialog">
                                <button
                                    type="button"
                                    class="btn-ghost btn-sm btn-icon"
                                    data-action="confirm-dialog#open"
                                    title="{{ 'project.groups.remove'|trans }}"
                                    aria-label="{{ 'project.groups.remove'|trans }}"
                                >
                                    <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                        <path fill="currentColor" d="M6 19a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                                    </svg>
                                </button>
                                <dialog
                                    class="confirm-dialog confirm-dialog--form"
                                    data-confirm-dialog-target="dialog">

                                    <form
                                        method="post"
                                        action="{{ path('project_groups_remove', {projectId: project.uuid, groupAccessId: groupAccess.uuid}) }}"
                                        class="confirm-dialog__panel"
                                    >
                                        <h3 class="confirm-dialog__title">{{ 'project.groups.remove_title'|trans }}</h3>
                                        <p class="confirm-dialog__body">{{ 'project.groups.remove_confirm'|trans({'%name%': linkedGroup.name}) }}</p>
                                        <input type="hidden" name="_token" value="{{ csrf_token('project_group_remove_' ~ groupAccess.id) }}">
                                        <div class="confirm-dialog__actions">
                                            <button type="button" class="btn-ghost" data-confirm-dialog-close>{{ 'project.danger.cancel'|trans }}</button>
                                            <button class="btn-danger" type="submit">{{ 'project.groups.remove'|trans }}</button>
                                        </div>
                                    </form>
                                </dialog>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </li>
        {% else %}
            <li class="text-[var(--color-ink)]/55">{{ 'project.groups.empty'|trans }}</li>
        {% endfor %}
    </ul>

    {% if assignableGroupRoles is not empty %}
        {% if availableGroups is not empty %}
            <form method="post" action="{{ path('project_groups_add', {id: project.uuid}) }}" class="mt-4 grid gap-2 sm:grid-cols-[1fr_auto_auto]">
                <input type="hidden" name="_token" value="{{ csrf_token('project_group_add_' ~ project.id) }}">
                <select class="input" name="group" required>
                    <option value="">{{ 'project.groups.select'|trans }}</option>
                    {% for g in availableGroups %}
                        <option value="{{ g.uuid }}">{{ g.name }} ({{ g.memberships|length }})</option>
                    {% endfor %}
                </select>
                <select class="input" name="role">
                    {% for role in assignableGroupRoles %}
                        <option value="{{ role.value }}" {% if role.value == 'member' %}selected{% endif %}>{{ ('project.members.role.' ~ role.value)|trans }}</option>
                    {% endfor %}
                </select>
                <button class="btn-primary" type="submit">{{ 'project.groups.add'|trans }}</button>
            </form>
        {% else %}
            <p class="mt-3 text-xs text-[var(--color-ink)]/55">{{ 'project.groups.none_available'|trans }}</p>
        {% endif %}
    {% endif %}
</section>

<section class="panel mt-6">
    <h2 class="mb-3 text-lg font-semibold">{{ 'project.health.title'|trans }}</h2>
    <p class="mb-4 text-sm text-[var(--color-ink)]/65">{{ 'project.health.intro'|trans }}</p>
    <dl class="mb-4 grid gap-3 text-sm sm:grid-cols-2">
        <div>
            <dt class="text-[var(--color-ink)]/55">{{ 'project.health.messenger_pending'|trans }}</dt>
            <dd class="mt-1 font-medium">
                {% if messengerQueue.available %}
                    {{ messengerQueue.pending }}
                    <span class="text-xs font-normal text-[var(--color-ink)]/55">({{ 'project.health.instance_wide'|trans }})</span>
                {% else %}
                    {{ 'project.health.messenger_unavailable'|trans }}
                    — <a href="{{ path('health_ready') }}">{{ 'project.health.ready_link'|trans }}</a>
                {% endif %}
            </dd>
        </div>
        <div>
            <dt class="text-[var(--color-ink)]/55">{{ 'project.health.ready_probe'|trans }}</dt>
            <dd class="mt-1"><a href="{{ path('health_ready') }}">/health/ready</a></dd>
        </div>
    </dl>
    <h3 class="mb-2 text-sm font-semibold">{{ 'project.health.destinations_title'|trans }}</h3>
    {% set destinations = project.notificationDestinations %}
    {% if destinations is empty %}
        <p class="text-sm text-[var(--color-ink)]/55">{{ 'project.health.destinations_empty'|trans }}</p>
    {% else %}
        <ul class="space-y-2 text-sm">
            {% for destination in destinations %}
                <li class="rounded-md border border-[var(--color-sand)] bg-[var(--color-paper)] p-3">
                    <div class="font-medium">{{ destination.label }}</div>
                    <div class="mt-1 text-xs text-[var(--color-ink)]/60">
                        {% if destination.lastDeliveryAt %}
                            {{ 'project.health.last_delivery'|trans }}
                            {{ destination.lastDeliveryAt|date('Y-m-d H:i') }}
                            —
                            {% if destination.lastDeliverySuccess %}
                                <span class="text-emerald-700">{{ 'project.health.delivery_ok'|trans }}</span>
                            {% else %}
                                <span class="text-[var(--color-alert)]">{{ 'project.health.delivery_fail'|trans }}</span>
                                {% if destination.lastDeliveryError %}
                                    · {{ destination.lastDeliveryError }}
                                {% endif %}
                            {% endif %}
                        {% else %}
                            {{ 'project.health.never_delivered'|trans }}
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</section>

<section class="panel mt-6">
    <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
        <h2 class="text-lg font-semibold">{{ 'notifications.title'|trans }}</h2>
        <div class="flex flex-wrap gap-2">
            <a class="btn-ghost" href="{{ path('project_notification_help', {id: project.uuid}) }}">{{ 'notifications.help.link'|trans }}</a>
            {% if membership.role.value in ['owner', 'admin'] %}
                <a class="btn-primary" href="{{ path('project_notification_new', {id: project.uuid}) }}">{{ 'notifications.add'|trans }}</a>
            {% endif %}
        </div>
    </div>
    <p class="mb-4 text-sm text-[var(--color-ink)]/65">{{ 'notifications.intro'|trans }}</p>
    {% set destinations = project.notificationDestinations %}
    {% if destinations is empty %}
        <p class="text-sm text-[var(--color-ink)]/55">{{ 'notifications.empty'|trans }}</p>
    {% else %}
        <ul class="space-y-3">
            {% for destination in destinations %}
                <li class="rounded-md border border-[var(--color-sand)] bg-[var(--color-paper)] p-3 text-sm">
                    <div class="flex flex-wrap items-start justify-between gap-2">
                        <div>
                            <div class="font-medium">
                                {{ destination.label }}
                                {% if not destination.enabled %}
                                    <span class="badge badge-error">{{ 'notifications.disabled'|trans }}</span>
                                {% endif %}
                            </div>
                            <div class="mt-1 text-xs text-[var(--color-ink)]/60">
                                {{ ('notifications.type.' ~ destination.type.value)|trans }}
                                · {{ destination.maskedEndpointUrl }}
                            </div>
                            <div class="mt-1 text-xs text-[var(--color-ink)]/55">
                                {% for category in destination.categories %}
                                    <span class="mr-1">{{ ('notifications.category.' ~ category)|trans }}</span>{% if not loop.last %},{% endif %}
                                {% endfor %}
                            </div>
                        </div>
                        {% if membership.role.value in ['owner', 'admin'] %}
                            <div class="flex flex-wrap gap-2">
                                <a class="btn-ghost" href="{{ path('project_notification_edit', {projectId: project.uuid, id: destination.uuid}) }}">{{ 'notifications.edit'|trans }}</a>
                                <form method="post" action="{{ path('project_notification_toggle', {projectId: project.uuid, id: destination.uuid}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('notif_toggle_' ~ destination.id) }}">
                                    <button class="btn-ghost" type="submit">{{ destination.enabled ? 'notifications.disable'|trans : 'notifications.enable'|trans }}</button>
                                </form>
                                <form method="post" action="{{ path('project_notification_test', {projectId: project.uuid, id: destination.uuid}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('notif_test_' ~ destination.id) }}">
                                    <button class="btn-ghost" type="submit">{{ 'notifications.test'|trans }}</button>
                                </form>
                                <form method="post" action="{{ path('project_notification_delete', {projectId: project.uuid, id: destination.uuid}) }}" onsubmit="return confirm('{{ 'notifications.delete_confirm'|trans|e('js') }}')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('notif_delete_' ~ destination.id) }}">
                                    <button class="btn-danger" type="submit">{{ 'notifications.delete'|trans }}</button>
                                </form>
                            </div>
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</section>

{% if membership.role.value in ['owner', 'admin'] %}
<section class="panel panel--danger mt-6">
    <h2 class="mb-2 text-lg font-semibold text-[var(--color-alert)]">{{ 'project.danger.title'|trans }}</h2>
    <p class="mb-4 text-sm text-[var(--color-ink)]/65">{{ 'project.danger.intro'|trans }}</p>

    <div class="flex flex-wrap gap-3">
        <div data-controller="confirm-dialog">
            <button type="button" class="btn-ghost" data-action="confirm-dialog#open">{{ 'project.danger.clear_open'|trans }}</button>
            <dialog
                class="confirm-dialog confirm-dialog--form"
                data-confirm-dialog-target="dialog">

                <form method="post" action="{{ path('project_clear_history', {id: project.uuid}) }}" class="confirm-dialog__panel">
                    <h3 class="confirm-dialog__title">{{ 'project.danger.clear_title'|trans }}</h3>
                    <p class="confirm-dialog__body">{{ 'project.danger.clear_body'|trans }}</p>
                    <input type="hidden" name="_token" value="{{ csrf_token('project_clear_' ~ project.id) }}">
                    <div class="confirm-dialog__actions">
                        <button type="button" class="btn-ghost" data-confirm-dialog-close>{{ 'project.danger.cancel'|trans }}</button>
                        <button type="submit" class="btn-danger">{{ 'project.danger.clear_confirm'|trans }}</button>
                    </div>
                </form>
            </dialog>
        </div>

        {% if membership.role.value == 'owner' %}
            <div data-controller="confirm-dialog" data-confirm-dialog-expected-value="{{ project.name|e('html_attr') }}">
                <button
                    type="button"
                    class="btn-ghost"
                    data-action="confirm-dialog#open"
                    title="{{ transferCandidates is empty ? 'project.danger.transfer_no_candidates'|trans : 'project.danger.transfer_open'|trans }}"
                >{{ 'project.danger.transfer_open'|trans }}</button>
                <dialog
                    class="confirm-dialog confirm-dialog--form"
                    data-confirm-dialog-target="dialog"
                >
                    <form method="post" action="{{ path('project_transfer_ownership', {projectId: project.uuid}) }}" class="confirm-dialog__panel">
                        <h3 class="confirm-dialog__title">{{ 'project.danger.transfer_title'|trans }}</h3>
                        {% if transferCandidates is empty %}
                            <p class="confirm-dialog__body">{{ 'project.danger.transfer_no_candidates'|trans }}</p>
                            <div class="confirm-dialog__actions">
                                <button type="button" class="btn-ghost" data-confirm-dialog-close>{{ 'project.danger.cancel'|trans }}</button>
                            </div>
                        {% else %}
                            <p class="confirm-dialog__body">{{ 'project.danger.transfer_body'|trans }}</p>
                            <input type="hidden" name="_token" value="{{ csrf_token('project_transfer_ownership_' ~ project.id) }}">
                            <label class="confirm-dialog__label" for="project-transfer-user-{{ project.id }}">{{ 'project.danger.transfer_member_label'|trans }}</label>
                            <select
                                id="project-transfer-user-{{ project.id }}"
                                class="input w-full"
                                name="user"
                                required
                            >
                                <option value="">{{ 'project.danger.transfer_member_placeholder'|trans }}</option>
                                {% for candidate in transferCandidates %}
                                    <option value="{{ candidate.user.uuid }}">{{ candidate.user.displayName }} ({{ candidate.user.email }}) — {{ ('project.members.role.' ~ candidate.role.value)|trans }}</option>
                                {% endfor %}
                            </select>
                            <label class="confirm-dialog__label mt-3" for="project-transfer-confirm-{{ project.id }}">
                                {{ 'project.danger.transfer_type_label'|trans({'%name%': project.name}) }}
                            </label>
                            <input
                                id="project-transfer-confirm-{{ project.id }}"
                                class="input"
                                name="confirmation"
                                autocomplete="off"
                                data-confirm-dialog-target="confirmInput"
                                required
                            >
                            <div class="confirm-dialog__actions">
                                <button type="button" class="btn-ghost" data-confirm-dialog-close>{{ 'project.danger.cancel'|trans }}</button>
                                <button type="submit" class="btn-danger" data-confirm-dialog-target="submit" disabled>{{ 'project.danger.transfer_confirm'|trans }}</button>
                            </div>
                        {% endif %}
                    </form>
                </dialog>
            </div>

            <div data-controller="confirm-dialog" data-confirm-dialog-expected-value="{{ project.name|e('html_attr') }}">
                <button type="button" class="btn-danger" data-action="confirm-dialog#open">{{ 'project.danger.delete_open'|trans }}</button>
                <dialog
                    class="confirm-dialog confirm-dialog--form"
                    data-confirm-dialog-target="dialog">

                    <form method="post" action="{{ path('project_delete', {id: project.uuid}) }}" class="confirm-dialog__panel">
                        <h3 class="confirm-dialog__title">{{ 'project.danger.delete_title'|trans }}</h3>
                        <p class="confirm-dialog__body">{{ 'project.danger.delete_body'|trans({'%name%': project.name}) }}</p>
                        <label class="confirm-dialog__label" for="project-delete-confirm-{{ project.id }}">
                            {{ 'project.danger.delete_type_label'|trans({'%name%': project.name}) }}
                        </label>
                        <input
                            id="project-delete-confirm-{{ project.id }}"
                            class="input"
                            name="confirmation"
                            autocomplete="off"
                            data-confirm-dialog-target="confirmInput"

                            required
                        >
                        <input type="hidden" name="_token" value="{{ csrf_token('project_delete_' ~ project.id) }}">
                        <div class="confirm-dialog__actions">
                            <button type="button" class="btn-ghost" data-confirm-dialog-close>{{ 'project.danger.cancel'|trans }}</button>
                            <button type="submit" class="btn-danger" data-confirm-dialog-target="submit" disabled>{{ 'project.danger.delete_confirm'|trans }}</button>
                        </div>
                    </form>
                </dialog>
            </div>
        {% endif %}
    </div>
</section>
{% endif %}
{% endblock %}
