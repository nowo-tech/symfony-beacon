{% extends 'base.html.twig' %}

{% block title %}{{ 'projects.title'|trans }} — {{ site_appearance.brandName }}{% endblock %}

{% block body %}
<div
    data-controller="confirm-dialog"
    data-confirm-dialog-open-on-connect-value="{{ openNewProject ? 'true' : 'false' }}"
>
    {% if showSetupBanner|default(false) %}
        <div class="panel mb-6 flex flex-col gap-3 border-[var(--color-moss)]/35 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <p class="text-sm font-semibold text-[var(--color-ink)]">{{ 'setup.banner.title'|trans }}</p>
                <p class="mt-1 text-sm text-[var(--color-ink)]/65">{{ 'setup.banner.body'|trans }}</p>
            </div>
            <a class="btn-primary shrink-0 no-underline" href="{{ path('setup_wizard') }}">{{ 'setup.banner.cta'|trans }}</a>
        </div>
    {% endif %}

    <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="min-w-0">
            <h1 class="font-[family-name:var(--font-display)] text-3xl font-bold">{{ 'projects.title'|trans }}</h1>
            <p class="mt-1 text-[var(--color-ink)]/65">{{ 'projects.intro'|trans }}</p>
        </div>
        <div class="flex w-full flex-col gap-2 sm:flex-row sm:items-center lg:w-auto lg:max-w-2xl lg:flex-1 lg:justify-end">
            <form
                method="get"
                action="{{ path('dashboard_home') }}"
                class="flex min-w-0 flex-1 items-center gap-2"
                role="search"
            >
                <input
                    class="input min-w-0 flex-1"
                    type="search"
                    name="q"
                    value="{{ query }}"
                    placeholder="{{ 'projects.search_placeholder'|trans }}"
                    autocomplete="off"
                    aria-label="{{ 'projects.search_placeholder'|trans }}"
                >
                <button class="btn-ghost shrink-0" type="submit">{{ 'common.filter'|trans }}</button>
                <a class="btn-ghost shrink-0 no-underline" href="{{ path('dashboard_home') }}">{{ 'common.clear_filters'|trans }}</a>
            </form>
            <button type="button" class="btn-primary shrink-0 sm:self-auto" data-action="confirm-dialog#open">
                {{ 'nav.new_project'|trans }}
            </button>
        </div>
    </div>

    {% if projects is empty %}
        <div class="panel text-center">
            <p class="mb-4 text-[var(--color-ink)]/70">{{ 'projects.empty'|trans }}</p>
            <button type="button" class="btn-primary" data-action="confirm-dialog#open">
                {{ 'projects.create_first'|trans }}
            </button>
        </div>
    {% else %}
        <div class="grid gap-4 md:grid-cols-2">
            {% for project in projects %}
                <a href="{{ path('project_show', {id: project.uuid}) }}" class="panel block no-underline transition hover:-translate-y-0.5 hover:shadow-md">
                    <h2 class="text-lg font-semibold text-[var(--color-ink)]">{{ project.name }}</h2>
                    <p class="mt-1 text-sm text-[var(--color-ink)]/60">{{ project.slug }}</p>
                    {% set days = statsPreview[project.id]|default([]) %}
                    {% if days %}
                        {% set errors = 0 %}
                        {% for day in days %}{% set errors = errors + day.errorCount %}{% endfor %}
                        <p class="mt-3 text-sm text-[var(--color-moss)]">{{ 'projects.errors_last_7_days'|trans({'%count%': errors}) }}</p>
                    {% endif %}
                </a>
            {% endfor %}
        </div>
    {% endif %}

    <dialog
        class="confirm-dialog"
        data-confirm-dialog-target="dialog"
        aria-labelledby="new-project-dialog-title"
    >
        {{ form_start(newProjectForm, {action: path('project_new'), attr: {class: 'confirm-dialog__panel'}}) }}
            <div class="confirm-dialog__header">
                <h2 id="new-project-dialog-title" class="confirm-dialog__title">{{ 'project.new.title'|trans }}</h2>
                <p class="confirm-dialog__body">{{ 'project.name.help'|trans }}</p>
            </div>
            <div class="confirm-dialog__content">
                {{ form_row(newProjectForm.name) }}
                {{ form_row(newProjectForm.description) }}
            </div>
            <div class="confirm-dialog__actions">
                <button type="button" class="btn-ghost" data-confirm-dialog-close>{{ 'common.cancel'|trans }}</button>
                <button class="btn-primary" type="submit">{{ 'project.new.submit'|trans }}</button>
            </div>
        {{ form_end(newProjectForm) }}
    </dialog>
</div>
{% endblock %}
