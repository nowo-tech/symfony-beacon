{% extends 'base.html.twig' %}

{% block title %}{{ 'issues.title'|trans }} — {{ project.name }}{% endblock %}

{% block body %}
{% include 'project/_nav.html.twig' with {project: project, current: 'issues'} %}

<form method="get" action="{{ path('issue_index', {id: project.id}) }}" class="issue-filters panel mb-6 grid gap-3 md:grid-cols-5">
    <input type="hidden" name="sort" value="{{ filters.sort }}">
    <input type="hidden" name="dir" value="{{ filters.dir }}">
    <input type="hidden" name="page" value="1">
    <input type="hidden" name="per_page" value="{{ filters.per_page }}">
    <input class="input" type="search" name="q" value="{{ filters.q }}" placeholder="{{ 'issues.search_placeholder'|trans }}">
    <select class="input" name="level">
        <option value="">{{ 'issues.filter.any_level'|trans }}</option>
        {% for level in ['fatal', 'error', 'warning', 'info', 'debug'] %}
            <option value="{{ level }}" {% if filters.level == level %}selected{% endif %}>{{ level }}</option>
        {% endfor %}
    </select>
    <select class="input" name="status">
        {% for status in ['unresolved', 'resolved', 'ignored', ''] %}
            <option value="{{ status }}" {% if filters.status == status %}selected{% endif %}>{{ status ? status : 'issues.filter.any_status'|trans }}</option>
        {% endfor %}
    </select>
    <select class="input" name="assignee">
        <option value="">{{ 'issues.filter.any_assignee'|trans }}</option>
        <option value="unassigned" {% if filters.assignee == 'unassigned' %}selected{% endif %}>{{ 'issues.assignee_unassigned'|trans }}</option>
        {% for member in members %}
            <option value="{{ member.id }}" {% if filters.assignee == (member.id ~ '') %}selected{% endif %}>{{ member.displayName ?: member.email }}</option>
        {% endfor %}
    </select>
    <div class="flex gap-2">
        <input class="input" name="environment" value="{{ filters.environment }}" placeholder="{{ 'issues.filter.environment'|trans }}">
        <button class="btn-primary" type="submit">{{ 'common.filter'|trans }}</button>
    </div>
</form>

{% if issues is empty %}
    <div class="panel text-[var(--color-ink)]/70">{{ 'issues.empty'|trans }}</div>
{% else %}
    <div class="panel issue-table-panel">
        <table
            class="issue-table display nowrap w-full text-left text-sm"
            style="width:100%"
            data-controller="datatable"
            data-datatable-sort-value="{{ filters.sort }}"
            data-datatable-dir-value="{{ filters.dir }}"
            data-datatable-page-value="{{ filters.page }}"
            data-datatable-per-page-value="{{ filters.per_page }}"
            data-datatable-empty-value="{{ 'issues.dt.empty'|trans|e('html_attr') }}"
            data-datatable-info-value="{{ 'issues.dt.info'|trans|e('html_attr') }}"
            data-datatable-info-empty-value="{{ 'issues.dt.info_empty'|trans|e('html_attr') }}"
            data-datatable-info-filtered-value="{{ 'issues.dt.info_filtered'|trans|e('html_attr') }}"
            data-datatable-length-menu-value="{{ 'issues.dt.length_menu'|trans|e('html_attr') }}"
            data-datatable-paginate-first-value="{{ 'issues.dt.first'|trans|e('html_attr') }}"
            data-datatable-paginate-last-value="{{ 'issues.dt.last'|trans|e('html_attr') }}"
            data-datatable-paginate-next-value="{{ 'issues.dt.next'|trans|e('html_attr') }}"
            data-datatable-paginate-previous-value="{{ 'issues.dt.previous'|trans|e('html_attr') }}"
            data-datatable-zero-records-value="{{ 'issues.dt.zero'|trans|e('html_attr') }}"
        >
            <thead>
                <tr>
                    <th>{{ 'issues.col.issue'|trans }}</th>
                    <th>{{ 'issues.col.level'|trans }}</th>
                    <th>{{ 'issues.col.assignee'|trans }}</th>
                    <th class="dt-head-right">{{ 'issues.col.events'|trans }}</th>
                    <th class="dt-head-right">{{ 'issues.col.events_24h'|trans }}</th>
                    <th class="dt-head-right">{{ 'issues.col.events_7d'|trans }}</th>
                    <th class="dt-head-right">{{ 'issues.col.events_30d'|trans }}</th>
                    <th>{{ 'issues.col.first_seen'|trans }}</th>
                    <th>{{ 'issues.col.last_seen'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for issue in issues %}
                    {% set occ = occurrenceByIssue[issue.id]|default(null) %}
                    {% set assigneeLabel = issue.assignee ? (issue.assignee.displayName ?: issue.assignee.email) : ('issues.assignee_unassigned'|trans) %}
                    <tr>
                        <td>
                            <a class="font-medium no-underline" href="{{ path('issue_show', {projectId: project.id, id: issue.id}) }}">{{ issue.title }}</a>
                            <div class="text-xs text-[var(--color-ink)]/55">{{ issue.culprit }}</div>
                        </td>
                        <td data-order="{{ issue.level }}">
                            <span class="badge {% if issue.level == 'error' or issue.level == 'fatal' %}badge-error{% else %}badge-warn{% endif %}">{{ issue.level }}</span>
                        </td>
                        <td data-order="{{ assigneeLabel }}">
                            {% if issue.assignee %}
                                {{ assigneeLabel }}
                            {% else %}
                                <span class="text-[var(--color-ink)]/45">{{ assigneeLabel }}</span>
                            {% endif %}
                        </td>
                        <td class="dt-body-right font-mono" data-order="{{ occ ? occ.total : issue.eventCount }}">{{ occ ? occ.total : issue.eventCount }}</td>
                        <td class="dt-body-right font-mono" data-order="{{ occ ? occ.last24h : 0 }}">{{ occ ? occ.last24h : '—' }}</td>
                        <td class="dt-body-right font-mono" data-order="{{ occ ? occ.last7d : 0 }}">{{ occ ? occ.last7d : '—' }}</td>
                        <td class="dt-body-right font-mono" data-order="{{ occ ? occ.last30d : 0 }}">{{ occ ? occ.last30d : '—' }}</td>
                        <td data-order="{{ issue.firstSeen|date('U') }}" class="whitespace-nowrap">{{ issue.firstSeen|date('Y-m-d H:i') }}</td>
                        <td data-order="{{ issue.lastSeen|date('U') }}" class="whitespace-nowrap">{{ issue.lastSeen|date('Y-m-d H:i') }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
