{% extends 'base.html.twig' %}

{% block title %}{{ 'issues.title'|trans }} — {{ project.name }}{% endblock %}

{% block body %}
{% include 'project/_nav.html.twig' with {project: project, current: 'issues'} %}

<form method="get" class="panel mb-6 grid gap-3 md:grid-cols-4">
    <input class="input" type="search" name="q" value="{{ filters.q }}" placeholder="{{ 'issues.search_placeholder'|trans }}">
    <select class="input" name="level">
        <option value="">{{ 'issues.filter.any_level'|trans }}</option>
        {% for level in ['fatal', 'error', 'warning', 'info', 'debug'] %}
            <option value="{{ level }}" {% if filters.level == level %}selected{% endif %}>{{ level }}</option>
        {% endfor %}
    </select>
    <select class="input" name="status">
        {% for status in ['unresolved', 'resolved', 'ignored', ''] %}
            <option value="{{ status }}" {% if filters.status == status %}selected{% endif %}>{{ status ? status : 'issues.filter.any_status'|trans }}</option>
        {% endfor %}
    </select>
    <div class="flex gap-2">
        <input class="input" name="environment" value="{{ filters.environment }}" placeholder="{{ 'issues.filter.environment'|trans }}">
        <button class="btn-primary" type="submit">{{ 'common.filter'|trans }}</button>
    </div>
</form>

{% if issues is empty %}
    <div class="panel text-[var(--color-ink)]/70">{{ 'issues.empty'|trans }}</div>
{% else %}
    <div class="panel overflow-x-auto p-0">
        <table class="w-full text-left text-sm">
            <thead class="border-b border-[var(--color-sand)] bg-[var(--color-paper)] text-xs uppercase tracking-wide text-[var(--color-ink)]/55">
                <tr>
                    <th class="px-4 py-3">{{ 'issues.col.issue'|trans }}</th>
                    <th class="px-4 py-3">{{ 'issues.col.level'|trans }}</th>
                    <th class="px-4 py-3">{{ 'issues.col.events'|trans }}</th>
                    <th class="px-4 py-3">{{ 'issues.col.last_seen'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for issue in issues %}
                    <tr class="row-hover border-b border-[var(--color-sand)] last:border-0">
                        <td class="px-4 py-3">
                            <a class="font-medium no-underline" href="{{ path('issue_show', {projectId: project.id, id: issue.id}) }}">{{ issue.title }}</a>
                            <div class="text-xs text-[var(--color-ink)]/55">{{ issue.culprit }}</div>
                        </td>
                        <td class="px-4 py-3"><span class="badge {% if issue.level == 'error' or issue.level == 'fatal' %}badge-error{% else %}badge-warn{% endif %}">{{ issue.level }}</span></td>
                        <td class="px-4 py-3">{{ issue.eventCount }}</td>
                        <td class="px-4 py-3 whitespace-nowrap">{{ issue.lastSeen|date('Y-m-d H:i') }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
