{% extends 'base.html.twig' %}

{% block title %}{{ issue.title }} — {{ project.name }}{% endblock %}

{% block body %}
{% set event = latestEvent %}
{% set payload = event ? event.payload : {} %}
{% set exception = payload.exception.values[0]|default(null) %}
{% set headline = exception.type|default(issue.title) %}
{% set subtitle = exception.value|default(payload.message|default(issue.culprit)) %}

<a href="{{ path('issue_index', {id: project.uuid}) }}" class="text-sm no-underline">{{ 'issues.back'|trans }}</a>

<header class="issue-hero mt-3">
    <p class="issue-hero__status">
        <span class="issue-badge issue-badge--status issue-badge--status-{{ issue.status.value }}">{{ ('issues.status.' ~ issue.status.value)|trans }}</span>
        <span class="issue-badge issue-badge--level">{{ issue.level }}</span>
        <span class="issue-badge issue-badge--priority issue-badge--priority-{{ issue.priority.value }}">{{ ('issues.priority.' ~ issue.priority.value)|trans }}</span>
    </p>
    <h1 class="issue-hero__title font-[family-name:var(--font-display)]">{{ headline }}</h1>
    {% if subtitle and subtitle != headline %}
        <p class="issue-hero__message">{{ subtitle }}</p>
    {% endif %}
    {% if issue.culprit %}
        <p class="issue-hero__culprit font-mono">{{ issue.culprit }}</p>
    {% endif %}
    {% if issue.duplicateOf %}
        <p class="issue-hero__duplicate mt-2 text-sm" data-testid="duplicate-of">
            {{ 'issues.duplicate_of'|trans }}
            <a href="{{ path('issue_show', {projectId: project.uuid, id: issue.duplicateOf.uuid}) }}">{{ issue.duplicateOf.title }}</a>
        </p>
    {% endif %}
</header>

<div class="issue-layout">
    <div class="issue-layout__main">
        {% if event %}
            {% include 'issue/_event_payload.html.twig' with {event: event, issue: issue} only %}
        {% else %}
            <section class="panel mt-6">
                <p class="text-[var(--color-ink)]/60">{{ 'issues.no_events'|trans }}</p>
            </section>
        {% endif %}

        <section class="panel mt-6 issue-comments" data-testid="issue-comments">
            <h2 class="text-base font-medium mb-3">{{ 'issues.comments_title'|trans }}</h2>
            {% if comments is empty %}
                <p class="text-[var(--color-ink)]/55 text-sm mb-4">{{ 'issues.comments_empty'|trans }}</p>
            {% else %}
                <ol class="issue-comments__list list-none space-y-3 mb-4">
                    {% for comment in comments %}
                        <li class="issue-comments__item border-t border-[var(--color-ink)]/10 pt-3 first:border-0 first:pt-0">
                            <div class="flex flex-wrap gap-2 text-xs text-[var(--color-ink)]/55 mb-1">
                                <span class="font-medium text-[var(--color-ink)]">{{ comment.author.displayName ?: comment.author.email }}</span>
                                <time datetime="{{ comment.createdAt|date('c') }}">{{ comment.createdAt|date('Y-m-d H:i') }}</time>
                            </div>
                            <p class="text-sm whitespace-pre-wrap">{{ comment.body }}</p>
                        </li>
                    {% endfor %}
                </ol>
            {% endif %}
            {% if can_triage|default(false) %}
            <form method="post" action="{{ path('issue_comment_add', {projectId: project.uuid, id: issue.uuid}) }}" class="issue-comments__form">
                <input type="hidden" name="_token" value="{{ csrf_token('issue_comment') }}">
                <label class="sr-only" for="issue-comment-body">{{ 'issues.comment_body'|trans }}</label>
                <textarea id="issue-comment-body" class="input w-full mb-2" name="body" rows="3" maxlength="5000" required placeholder="{{ 'issues.comment_placeholder'|trans }}"></textarea>
                <button type="submit" class="btn-primary">{{ 'issues.comment_submit'|trans }}</button>
            </form>
            {% else %}
                <p class="text-sm text-[var(--color-ink)]/55">{{ 'issues.viewer_readonly'|trans }}</p>
            {% endif %}
        </section>
    </div>

    <aside class="issue-layout__aside">
        {% embed 'issue/_collapse_section.html.twig' with {panel_id: 'details', title: 'issues.aside_details'|trans} %}
            {% block body %}
                <dl class="issue-aside-stats__grid">
                    <div>
                        <dt>{{ 'issues.col.events'|trans }}</dt>
                        <dd class="font-mono text-lg">{{ occurrence.total|default(issue.eventCount) }}</dd>
                    </div>
                    <div class="issue-aside-windows">
                        <div>
                            <dt>{{ 'issues.col.events_24h'|trans }}</dt>
                            <dd class="font-mono">{{ occurrence.last24h|default(0) }}</dd>
                        </div>
                        <div>
                            <dt>{{ 'issues.col.events_7d'|trans }}</dt>
                            <dd class="font-mono">{{ occurrence.last7d|default(0) }}</dd>
                        </div>
                        <div>
                            <dt>{{ 'issues.col.events_30d'|trans }}</dt>
                            <dd class="font-mono">{{ occurrence.last30d|default(0) }}</dd>
                        </div>
                    </div>
                    <div>
                        <dt>{{ 'issues.col.first_seen'|trans }}</dt>
                        <dd>{{ issue.firstSeen|date('Y-m-d H:i:s') }}</dd>
                    </div>
                    <div>
                        <dt>{{ 'issues.col.last_seen'|trans }}</dt>
                        <dd>{{ issue.lastSeen|date('Y-m-d H:i:s') }}</dd>
                    </div>
                    <div>
                        <dt>{{ 'issues.filter.environment'|trans }}</dt>
                        <dd>{{ event ? event.environment|default('—') : '—' }}</dd>
                    </div>
                    <div>
                        <dt>{{ 'projects.title'|trans }}</dt>
                        <dd><a href="{{ path('issue_index', {id: project.uuid}) }}">{{ project.name }}</a></dd>
                    </div>
                </dl>
            {% endblock %}
        {% endembed %}

        {% if can_triage|default(false) %}
        {% embed 'issue/_collapse_section.html.twig' with {panel_id: 'triage', title: 'issues.aside_triage'|trans} %}
            {% block body %}
                <div class="issue-triage">
                    <div class="issue-status-actions">
                        <p class="issue-assignee-form__help">{{ 'issues.status_help'|trans }}</p>
                        <div class="issue-status-actions__buttons">
                            {% if issue.status.value != 'resolved' %}
                                <form method="post" action="{{ path('issue_status', {projectId: project.uuid, id: issue.uuid}) }}" class="issue-status-actions__form">
                                    <input type="hidden" name="_token" value="{{ csrf_token('issue_status') }}">
                                    <input type="hidden" name="status" value="resolved">
                                    <button type="submit" class="btn-primary">{{ 'issues.status_mark_resolved'|trans }}</button>
                                </form>
                            {% endif %}
                            {% if issue.status.value != 'unresolved' %}
                                <form method="post" action="{{ path('issue_status', {projectId: project.uuid, id: issue.uuid}) }}" class="issue-status-actions__form">
                                    <input type="hidden" name="_token" value="{{ csrf_token('issue_status') }}">
                                    <input type="hidden" name="status" value="unresolved">
                                    <button type="submit" class="btn-ghost">{{ 'issues.status_mark_unresolved'|trans }}</button>
                                </form>
                            {% endif %}
                            {% if issue.status.value != 'ignored' %}
                                <form method="post" action="{{ path('issue_status', {projectId: project.uuid, id: issue.uuid}) }}" class="issue-status-actions__form">
                                    <input type="hidden" name="_token" value="{{ csrf_token('issue_status') }}">
                                    <input type="hidden" name="status" value="ignored">
                                    <button type="submit" class="btn-ghost">{{ 'issues.status_mark_ignored'|trans }}</button>
                                </form>
                            {% endif %}
                        </div>
                    </div>

                    <div class="issue-priority-actions">
                        <p class="issue-assignee-form__help">{{ 'issues.priority_help'|trans }}</p>
                        <form method="post" action="{{ path('issue_priority', {projectId: project.uuid, id: issue.uuid}) }}" class="issue-priority-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('issue_priority') }}">
                            <select class="input" name="priority" aria-label="{{ 'issues.priority_label'|trans }}">
                                {% for p in priorities %}
                                    <option value="{{ p.value }}" {% if issue.priority.value == p.value %}selected{% endif %}>{{ ('issues.priority.' ~ p.value)|trans }}</option>
                                {% endfor %}
                            </select>
                            <button type="submit" class="btn-primary">{{ 'issues.priority_save'|trans }}</button>
                        </form>
                    </div>
                </div>
            {% endblock %}
        {% endembed %}

        {% embed 'issue/_collapse_section.html.twig' with {panel_id: 'assignee', title: 'issues.assignee'|trans} %}
            {% block body %}
                <p class="issue-assignee-form__help">{{ 'issues.assignee_help'|trans }}</p>
                {{ form_start(assigneeForm, {attr: {class: 'issue-assignee-form'}}) }}
                    {{ form_widget(assigneeForm.assignee) }}
                    {{ form_errors(assigneeForm.assignee) }}
                    <button class="btn-primary issue-assignee-form__submit" type="submit">{{ 'issues.assignee_save'|trans }}</button>
                {{ form_end(assigneeForm) }}
            {% endblock %}
        {% endembed %}

        {% embed 'issue/_collapse_section.html.twig' with {panel_id: 'duplicate', title: 'issues.aside_duplicate'|trans} %}
            {% block body %}
                <div class="issue-duplicate-actions" data-testid="mark-duplicate" data-controller="confirm-dialog">
                    <p class="issue-assignee-form__help">{{ 'issues.duplicate_aside_help'|trans }}</p>
                    <button
                        type="button"
                        class="btn-ghost w-full"
                        data-action="confirm-dialog#open"
                        {% if duplicateCandidates is empty %}disabled{% endif %}
                    >
                        {{ 'issues.duplicate_open'|trans }}
                    </button>
                    {% if duplicateCandidates is empty %}
                        <p class="mt-2 text-xs text-[var(--color-ink)]/55">{{ 'issues.duplicate_no_candidates'|trans }}</p>
                    {% endif %}

                    <dialog
                        class="confirm-dialog confirm-dialog--wide"
                        data-confirm-dialog-target="dialog"
                        aria-labelledby="issue-duplicate-dialog-title"
                    >
                        <form
                            method="post"
                            action="{{ path('issue_mark_duplicate', {projectId: project.uuid, id: issue.uuid}) }}"
                            class="confirm-dialog__panel"
                            data-controller="combobox"
                            data-action="submit->combobox#requireValue"
                        >
                            <div class="confirm-dialog__header">
                                <h2 id="issue-duplicate-dialog-title" class="confirm-dialog__title">{{ 'issues.duplicate_modal_title'|trans }}</h2>
                                <p class="confirm-dialog__body">{{ 'issues.duplicate_help'|trans }}</p>
                            </div>

                            <div class="confirm-dialog__content">
                                <input type="hidden" name="_token" value="{{ csrf_token('issue_duplicate') }}">
                                <input type="hidden" name="canonical_uuid" value="" data-combobox-target="value">

                                <label class="confirm-dialog__label" for="issue-duplicate-query">{{ 'issues.duplicate_canonical'|trans }}</label>
                                <div class="combobox combobox--stacked">
                                    <input
                                        id="issue-duplicate-query"
                                        type="search"
                                        class="input w-full"
                                        autocomplete="off"
                                        placeholder="{{ 'issues.duplicate_search_placeholder'|trans }}"
                                        data-combobox-target="query"
                                        data-confirm-dialog-target="confirmInput"
                                        data-required-message="{{ 'issues.duplicate_choose'|trans }}"
                                        data-action="input->combobox#filter focus->combobox#onQueryFocus keydown->combobox#onQueryKeydown"
                                        aria-autocomplete="list"
                                        aria-controls="issue-duplicate-options"
                                    >
                                    <ul
                                        id="issue-duplicate-options"
                                        class="combobox__list"
                                        role="listbox"
                                        data-combobox-target="list"
                                        hidden
                                    >
                                        {% for candidate in duplicateCandidates|default([]) %}
                                            <li role="presentation">
                                                <button
                                                    type="button"
                                                    class="combobox__option"
                                                    role="option"
                                                    data-combobox-target="option"
                                                    data-action="combobox#select"
                                                    data-value="{{ candidate.uuid }}"
                                                    data-label="{{ candidate.title|e('html_attr') }}"
                                                    data-search="{{ (candidate.title ~ ' ' ~ candidate.uuid)|e('html_attr') }}"
                                                >
                                                    <span class="combobox__option-title">{{ candidate.title }}</span>
                                                    <span class="combobox__option-meta">{{ candidate.uuid|slice(0, 8) }}…</span>
                                                </button>
                                            </li>
                                        {% endfor %}
                                        <li
                                            class="combobox__empty"
                                            data-combobox-target="empty"
                                            hidden
                                        >{{ 'issues.duplicate_search_empty'|trans }}</li>
                                    </ul>
                                </div>

                                <label class="confirm-dialog__check">
                                    <input type="checkbox" name="merge_events" value="1">
                                    <span>
                                        <span class="confirm-dialog__check-label">{{ 'issues.merge_events_label'|trans }}</span>
                                        <span class="confirm-dialog__check-help">{{ 'issues.merge_events_help'|trans }}</span>
                                    </span>
                                </label>
                            </div>

                            <div class="confirm-dialog__actions">
                                <button type="button" class="btn-ghost" data-confirm-dialog-close>{{ 'issues.duplicate_cancel'|trans }}</button>
                                <button type="submit" class="btn-primary">{{ 'issues.duplicate_submit'|trans }}</button>
                            </div>
                        </form>
                    </dialog>
                </div>
            {% endblock %}
        {% endembed %}

        {% else %}
        <div class="panel mt-4 text-sm text-[var(--color-ink)]/55" data-testid="viewer-readonly">{{ 'issues.viewer_readonly'|trans }}</div>
        {% endif %}

        {% embed 'issue/_collapse_section.html.twig' with {panel_id: 'activity', title: 'issues.history_title'|trans} %}
            {% block body %}
                <div class="issue-history">
                    {% if issueHistory is empty %}
                        <p class="issue-history__empty">{{ 'issues.history_empty'|trans }}</p>
                    {% else %}
                        <ol class="issue-history__list">
                            {% for entry in issueHistory %}
                                <li class="issue-history__item">
                                    <time class="issue-history__when" datetime="{{ entry.createdAt|date('c') }}">{{ entry.createdAt|date('Y-m-d H:i') }}</time>
                                    <div class="issue-history__body">
                                        {% if entry.kind.value == 'assignee_changed' %}
                                            <span class="issue-history__kind">{{ 'issues.history_assignee'|trans }}</span>
                                            <span>
                                                {{ entry.fromAssignee ? entry.fromAssignee.displayName : ('issues.assignee_unassigned'|trans) }}
                                                →
                                                {{ entry.toAssignee ? entry.toAssignee.displayName : ('issues.assignee_unassigned'|trans) }}
                                            </span>
                                        {% else %}
                                            <span class="issue-history__kind">{{ 'issues.history_status'|trans }}</span>
                                            <span>
                                                {{ entry.fromStatus ? ('issues.status.' ~ entry.fromStatus.value)|trans : '—' }}
                                                →
                                                {{ entry.toStatus ? ('issues.status.' ~ entry.toStatus.value)|trans : '—' }}
                                            </span>
                                        {% endif %}
                                        <span class="issue-history__actor">
                                            {% if entry.actor %}
                                                {{ 'issues.history_by'|trans({'%name%': entry.actor.displayName}) }}
                                            {% else %}
                                                {{ 'issues.history_by_system'|trans }}
                                            {% endif %}
                                        </span>
                                    </div>
                                </li>
                            {% endfor %}
                        </ol>
                    {% endif %}
                </div>
            {% endblock %}
        {% endembed %}

        {% embed 'issue/_collapse_section.html.twig' with {panel_id: 'recent_events', title: 'issues.recent_events'|trans} %}
            {% block body %}
                <ul class="issue-event-list">
                    {% for e in events %}
                        <li>
                            <a href="{{ path('event_show', {projectId: project.uuid, eventId: e.eventId}) }}" class="font-mono text-xs">{{ e.eventId|slice(0, 12) }}…</a>
                            <span class="text-[var(--color-ink)]/50 text-xs">{{ e.receivedAt|date('H:i:s') }}</span>
                        </li>
                    {% else %}
                        <li class="text-[var(--color-ink)]/60 text-sm">{{ 'issues.no_events'|trans }}</li>
                    {% endfor %}
                </ul>
            {% endblock %}
        {% endembed %}
    </aside>
</div>
{% endblock %}
