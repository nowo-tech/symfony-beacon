<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
        {% if app.user and app.user.preferredTheme %}
            <script>window.__BEACON_USER_THEME__ = {{ app.user.preferredTheme|json_encode|raw }};</script>
        {% endif %}
        {% if app.user %}
            <script>
                window.__BEACON_USER_DENSITY__ = {{ app.user.preferredUiDensity|json_encode|raw }};
                window.__BEACON_USER_MOTION__ = {{ app.user.preferredMotion|json_encode|raw }};
                window.__BEACON_USER_FONT_SCALE__ = {{ app.user.preferredFontScale|json_encode|raw }};
                window.__BEACON_USER_CONTRAST__ = {{ app.user.preferredContrast|json_encode|raw }};
                window.__BEACON_USER_SIDEBAR__ = {{ app.user.preferredSidebar|json_encode|raw }};
            </script>
        {% endif %}
        <script>
            window.__BEACON_ISSUE_PANEL_DEFAULTS__ = {{ (app.user ? app.user.preferredCollapsedIssuePanels : ['raw', 'extra'])|json_encode|raw }};
        </script>
        {% include '_theme_boot.html.twig' %}
        <title>{% block title %}{{ site_appearance.brandName }}{% endblock %}</title>
        <style>{{ site_appearance.cssOverrides|raw }}</style>
        {{ nowo_pwa_head() }}
        <link rel="icon" href="{{ asset('favicon.ico') }}" sizes="any">
        <link rel="icon" href="{{ asset('brand/beacon-mark.svg') }}" type="image/svg+xml">
        <link rel="apple-touch-icon" href="{{ asset('icons/apple-touch-icon.png') }}">
        {% block stylesheets %}
            {{ vite_entry_link_tags('app') }}
        {% endblock %}
        {% block javascripts %}
            {{ vite_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body class="page-shell{% if app.user %} page-shell--app{% endif %}">
        {% if app.user %}
            <div
                class="app-shell{% if app.user.preferredContentWidth == 'full' %} is-full-width{% else %} is-content-width{% endif %}{% if app.user.preferredSidebar == 'collapsed' %} is-sidebar-collapsed{% endif %}"
                data-app-shell
                data-content-width="{{ app.user.preferredContentWidth }}"
                data-ui-density="{{ app.user.preferredUiDensity }}"
                data-font-scale="{{ app.user.preferredFontScale }}"
                data-contrast="{{ app.user.preferredContrast|default('system') }}"
                data-sidebar-default="{{ app.user.preferredSidebar }}"
                data-theme-sync-url="{{ path('account_theme') }}"
                data-theme-sync-token="{{ csrf_token('account_theme') }}"
            >
                <header class="app-header">
                    <div class="app-header__start">
                        <button
                            type="button"
                            class="app-sidebar-toggle"
                            data-sidebar-toggle
                            aria-controls="app-sidebar"
                            aria-expanded="true"
                            aria-label="{{ 'nav.toggle_sidebar'|trans }}"
                        >
                            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                            </svg>
                        </button>
                        {% include '_brand_mark.html.twig' with {size: 'sm'} %}
                    </div>
                    <div class="app-header__end">
                        {% include '_theme_toggle.html.twig' with {compact: true} %}
                        {% include '_locale_switcher.html.twig' with {compact: true} %}
                        {% include '_user_menu.html.twig' %}
                    </div>
                </header>

                <aside id="app-sidebar" class="app-sidebar" data-app-sidebar data-tour="sidebar" aria-label="{{ app_section.current.labelKey|trans }}">
                    <div class="app-sidebar__inner">
                        <p class="app-sidebar__label">{{ app_section.current.labelKey|trans }}</p>
                        <div class="app-sidebar__nav">
                            {% include '_section_nav.html.twig' %}
                        </div>
                    </div>
                </aside>

                <div class="app-main">
                    <main class="app-main__inner">
        {% else %}
            <main class="auth-shell-main relative z-10 mx-auto flex w-full max-w-6xl flex-1 justify-center px-4 py-12">
        {% endif %}

                        {% if app.user %}
                            {% set beacon_breadcrumbs = breadcrumb_render() %}
                            {% if beacon_breadcrumbs %}
                                <div class="beacon-breadcrumb-wrap mb-6">{{ beacon_breadcrumbs|raw }}</div>
                            {% endif %}
                            {% if is_granted('ROLE_ADMIN') and app.session.get('_beacon_view_as_member') %}
                                <div class="mb-4 flex flex-wrap items-center justify-between gap-3 rounded-md border border-amber-600/40 bg-amber-500/10 px-4 py-3 text-sm" role="status">
                                    <span>{{ 'admin_projects.view_as_banner'|trans }}</span>
                                    <form method="post" action="{{ path('admin_view_as_member_disable') }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_view_as_member_disable') }}">
                                        <input type="hidden" name="redirect" value="{{ app.request.requestUri }}">
                                        <button class="btn-ghost btn-sm" type="submit">{{ 'admin_projects.view_as_exit'|trans }}</button>
                                    </form>
                                </div>
                            {% endif %}
                        {% endif %}
                        {% block app_flashes %}
                            {% include '_toasts.html.twig' %}
                        {% endblock %}
                        {% block body %}{% endblock %}

        {% if app.user %}
                    </main>
                </div>
                {% include '_legal_footer.html.twig' %}
            </div>
            <div class="app-sidebar-backdrop" data-sidebar-backdrop hidden></div>
            {{ nowo_pwa_install_prompt() }}
        {% else %}
            </main>
            {{ nowo_pwa_install_prompt() }}
            {% include '_legal_footer.html.twig' %}
        {% endif %}

        {# Modal available site-wide for footer “Cookie settings”; no floating bubble here. #}
        {{ render(path('nowo_cookie_consent.show')) }}
    </body>
</html>
