<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}symfony-beacon{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=Source+Serif+4:opsz,wght@8..60,600;8..60,700&display=swap" rel="stylesheet">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🟩</text></svg>">
        {% block stylesheets %}
            {{ vite_entry_link_tags('app') }}
        {% endblock %}
        {% block javascripts %}
            {{ vite_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body class="bg-[radial-gradient(circle_at_top_left,_#e7f0eb,_#f3f6f4_45%,_#eef2ef)]">
        {% if app.user %}
            <header class="border-b border-[var(--color-sand)] bg-white/70 backdrop-blur">
                <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
                    <a href="{{ path('dashboard_home') }}" class="font-[family-name:var(--font-display)] text-xl font-bold tracking-tight text-[var(--color-ink)] no-underline">
                        symfony-beacon
                    </a>
                    <nav class="flex items-center gap-3 text-sm">
                        <a href="{{ path('dashboard_home') }}" class="no-underline text-[var(--color-ink)]/80 hover:text-[var(--color-moss)]">Projects</a>
                        <a href="{{ path('project_new') }}" class="btn-ghost no-underline">New project</a>
                        <span class="text-[var(--color-ink)]/60">{{ app.user.userIdentifier }}</span>
                        <a href="{{ path('app_logout') }}" class="btn-ghost no-underline">Log out</a>
                    </nav>
                </div>
            </header>
        {% endif %}

        <main class="mx-auto max-w-6xl px-4 py-8">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mb-4 rounded-md border px-4 py-3 text-sm {% if label == 'error' %}border-red-200 bg-red-50 text-red-800{% else %}border-emerald-200 bg-emerald-50 text-emerald-900{% endif %}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
