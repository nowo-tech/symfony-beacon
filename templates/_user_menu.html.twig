{# Avatar dropdown: three section entry points (+ logout). #}
{% set user = app.user %}
<div class="user-menu" data-user-menu>
    <details class="user-menu__details">
        <summary class="user-menu__summary" aria-label="{{ 'nav.account'|trans }}">
            <span class="user-avatar" aria-hidden="true">{{ user.initials }}</span>
        </summary>
        <div class="user-menu__panel" role="menu">
            <div class="user-menu__identity">
                <span class="user-avatar user-avatar--sm" aria-hidden="true">{{ user.initials }}</span>
                <div class="user-menu__meta">
                    <p class="user-menu__name">{{ user.displayName }}</p>
                    <p class="user-menu__email">{{ user.userIdentifier }}</p>
                </div>
            </div>

            <a class="user-menu__link{{ app_section.current.value == 'preferences' ? ' is-current' : '' }}" role="menuitem" href="{{ path('account_profile') }}">{{ 'nav.preferences'|trans }}</a>
            <a class="user-menu__link{{ app_section.current.value == 'dashboard' ? ' is-current' : '' }}" role="menuitem" href="{{ path('dashboard_home') }}">{{ 'nav.dashboard'|trans }}</a>
            {% if is_granted('ROLE_ADMIN') %}
                <a class="user-menu__link{{ app_section.current.value == 'administration' ? ' is-current' : '' }}" role="menuitem" href="{{ path('admin_hub') }}">{{ 'nav.admin'|trans }}</a>
            {% endif %}

            <div class="user-menu__footer">
                <a class="user-menu__link user-menu__link--danger" role="menuitem" href="{{ path('nowo_auth_kit_logout', auth_kit_route_params()) }}">{{ 'nav.log_out'|trans }}</a>
            </div>
        </div>
    </details>
</div>
