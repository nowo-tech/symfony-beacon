{
    "name": "nowo-tech/symfony-beacon",
    "type": "project",
    "license": "MIT",
    "description": "Self-hosted error tracking for PHP/Symfony \u2014 Envelope wire protocol compatible, FrankenPHP worker, MySQL, Spec-Driven Development",
    "homepage": "https://github.com/nowo-tech/symfony-beacon",
    "authors": [
        {
            "name": "Nowo.tech",
            "homepage": "https://nowo.tech"
        },
        {
            "name": "H\u00e9ctor Franco Aceituno",
            "email": "hectorfranco@nowo.tech",
            "homepage": "https://github.com/HecFranco",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/nowo-tech/symfony-beacon",
        "issues": "https://github.com/nowo-tech/symfony-beacon/issues",
        "docs": "https://github.com/nowo-tech/symfony-beacon/tree/main/docs"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "3.2.4",
        "doctrine/doctrine-migrations-bundle": "4.0.0",
        "doctrine/orm": "3.6.7",
        "nowo-tech/auth-kit-bundle": "1.5.1",
        "nowo-tech/breadcrumb-kit-bundle": "2.0.2",
        "nowo-tech/cookie-consent-bundle": "1.3.3",
        "nowo-tech/dashboard-menu-bundle": "0.3.45",
        "nowo-tech/form-kit-bundle": "2.0.15",
        "nowo-tech/password-strength-bundle": "1.3.0",
        "nowo-tech/password-toggle-bundle": "2.0.4",
        "nowo-tech/pwa-bundle": "1.1.2",
        "pentatrion/vite-bundle": "8.2.4",
        "symfony/console": "8.1.1",
        "symfony/doctrine-messenger": "8.1.1",
        "symfony/dotenv": "8.1.0",
        "symfony/flex": "2.11.0",
        "symfony/form": "8.1.1",
        "symfony/framework-bundle": "8.1.1",
        "symfony/http-client": "8.1.1",
        "symfony/messenger": "8.1.1",
        "symfony/password-hasher": "8.1.0",
        "symfony/runtime": "8.1.0",
        "symfony/security-bundle": "8.1.1",
        "symfony/security-csrf": "8.1.0",
        "symfony/string": "8.1.0",
        "symfony/translation": "8.1.1",
        "symfony/twig-bundle": "8.1.0",
        "symfony/ux-icons": "2.36.1",
        "symfony/ux-native": "^3.3",
        "symfony/ux-turbo": "^3.3",
        "symfony/validator": "8.1.1",
        "symfony/yaml": "8.1.1",
        "twig/extra-bundle": "3.24.0",
        "twig/twig": "3.28.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": false,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "cs-check": "php-cs-fixer check --diff",
        "cs-fix": "php-cs-fixer fix",
        "twig-cs": "twig-cs-fixer lint --config=.twig-cs-fixer.dist.php",
        "twig-cs-fix": "twig-cs-fixer fix --config=.twig-cs-fixer.dist.php",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "rector": "rector process --dry-run",
        "rector-fix": "rector process",
        "test": "phpunit",
        "qa": [
            "@cs-check",
            "@twig-cs",
            "@phpstan",
            "@rector",
            "@test"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "8.1.*",
            "docker": true
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "3.95.15",
        "nowo-tech/twig-inspector-bundle": "1.0.36",
        "phpstan/phpstan": "2.2.5",
        "phpstan/phpstan-doctrine": "2.0.28",
        "phpstan/phpstan-symfony": "2.0.20",
        "phpunit/phpunit": "13.2.4",
        "rector/rector": "2.5.7",
        "symfony/browser-kit": "8.1.1",
        "symfony/css-selector": "8.1.0",
        "symfony/web-profiler-bundle": "8.1.1",
        "vincentlanglet/twig-cs-fixer": "4.0.2"
    }
}
