# =============================================================================
# Environment template (ONLY versioned env file)
# =============================================================================
# Install:  cp .env.dist .env
# Runtime:  Docker Compose and Symfony read `.env` (never commit it).
# Optional local overrides (gitignored): `.env.local`
# Do not use `.env.dev` / `.env.prod` in this project — keep one template.
# =============================================================================

# Server (host ports → container 80/443)
SERVER_NAME=localhost
HTTP_PORT=9081
HTTPS_PORT=9444
HTTP3_PORT=9444
DEFAULT_URI=https://localhost:9444

# -----------------------------------------------------------------------------
# Vite / Pentatrion (Compose service `vite`, pnpm in the FrankenPHP image)
# Host port maps to container 5173; browser loads /build via HTTPS (Caddy proxy).
VITE_PORT=5174
VITE_DEV_SERVER_HOST=localhost
# Set to 1 on Docker Desktop / WSL if HMR misses file changes (polling).
# VITE_USE_POLLING=1

# -----------------------------------------------------------------------------
# FrankenPHP mode (classic | worker) — HTTP, NOT Messenger
# -----------------------------------------------------------------------------
# Coding implications: docs/FRANKENPHP-CODING.md
#   classic              → boot per request
#   worker + RESET=false → shared Kernel; use ResetInterface (default, fastest)
#   worker + RESET=true  → clone Kernel per request (safer container, slower)
#
# After changing mode: `make restart` or `docker compose up -d` (recreate).
FRANKENPHP_MODE=classic
# FRANKENPHP_WORKER_NUM=4
FRANKENPHP_LOOP_MAX=500
FRANKENPHP_RESET_KERNEL=false

# Xdebug: off | develop | debug | coverage
XDEBUG_MODE=off

# Symfony
###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=ChangeMePleaseUseARealSecret
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

# -----------------------------------------------------------------------------
# MySQL (latest stable official: 9.7 — https://hub.docker.com/_/mysql)
# -----------------------------------------------------------------------------
MYSQL_VERSION=9.7
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=!ChangeMe!
MYSQL_ROOT_PASSWORD=!ChangeMeRoot!
MYSQL_PORT=3308

###> doctrine/doctrine-bundle ###
# Host `database` + port 3306 = Compose service (internal). MYSQL_PORT is host-only.
DATABASE_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@database:3306/${MYSQL_DATABASE}?serverVersion=${MYSQL_VERSION}&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Async queue in MySQL. Consumed by the Compose `messenger` service.
# Alternatives:
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=1
###< symfony/messenger ###

# -----------------------------------------------------------------------------
# Ops / self-hosting (roadmap Phase 2)
# -----------------------------------------------------------------------------
# Retention: 0 disables. Purge via `bin/console app:retention:purge` (cron daily).
BEACON_RETENTION_DAYS=0
BEACON_RETENTION_MAX_EVENTS_PER_PROJECT=0
# Envelope POST /api/{id}/envelope/ sliding window per project (0 = unlimited).
BEACON_INGEST_RATE_LIMIT=120
# Daily event quota per project (0 = unlimited). Project Settings can override.
BEACON_EVENT_QUOTA_DAILY=0
# Set to 1 only for local webhooks to private hosts (default 0 / blocked in prod).
BEACON_NOTIFICATIONS_ALLOW_PRIVATE_URLS=0
# Retained delivery attempts per notification destination in Project Settings.
BEACON_NOTIFICATION_DELIVERY_HISTORY_LIMIT=20

# -----------------------------------------------------------------------------
# Field encryption (nowo-tech/doctrine-encrypt-bundle)
# -----------------------------------------------------------------------------
# Default: Halite key file at var/secrets/.Halite.default.key (auto-created).
# Production: generate once and persist the file, or switch the YAML profile to
# secret_key_env_var and set APP_ENCRYPT_KEY (Halite hex key from
# `bin/console doctrine:encrypt:generate-secret-key`).
# APP_ENCRYPT_KEY=

###> symfony/mailer ###
# Bootstrap / fallback only when Administration → Mailer has no DSN stored.
# Prefer saving the real DSN encrypted under /settings/mailer (instance_settings).
MAILER_DSN=null://null
###< symfony/mailer ###
